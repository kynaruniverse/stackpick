---
// src/components/CookieConsent.astro
---
<div id="cookie-consent" class="cookie-banner" style="display: none;">
  <div class="cookie-content">
    <div class="cookie-text">
      <h3>Cookie Consent</h3>
      <p>We use cookies and analytics to improve your experience. By continuing to use this site, you agree to our use of cookies.</p>
      <a href="/privacy/" class="cookie-link">Learn more</a>
    </div>
    <div class="cookie-buttons">
      <button id="cookie-accept" class="btn-cookie btn-cookie--primary">Accept All</button>
      <button id="cookie-reject" class="btn-cookie btn-cookie--secondary">Reject</button>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    const consentKey = 'sp-cookie-consent';
    const banner = document.getElementById('cookie-consent');
    const acceptBtn = document.getElementById('cookie-accept');
    const rejectBtn = document.getElementById('cookie-reject');
    
    if (!banner || !acceptBtn || !rejectBtn) return;

    const consent = localStorage.getItem(consentKey);
    if (!consent) {
      banner.style.display = 'flex';
    }

    acceptBtn.addEventListener('click', () => {
      localStorage.setItem(consentKey, 'accepted');
      banner.style.display = 'none';
      window.location.reload(); // Reload to trigger analytics scripts
    });

    rejectBtn.addEventListener('click', () => {
      localStorage.setItem(consentKey, 'rejected');
      banner.style.display = 'none';
    });
  })();
</script>

<style>
  .cookie-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--color-bg-card);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid var(--color-border);
    padding: var(--space-4) var(--page-pad-mobile);
    display: flex;
    justify-content: center;
    z-index: 10000;
    box-shadow: 0 -8px 32px rgba(0,0,0,0.3);
  }
  .cookie-content {
    max-width: 1200px;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-6);
  }
  .cookie-text h3 { font-size: 14px; font-weight: 800; margin-bottom: 2px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-primary); }
  .cookie-text p { font-size: 12px; color: var(--color-text-muted); line-height: 1.4; }
  .cookie-link { font-size: 11px; color: var(--color-accent); text-decoration: underline; font-weight: 600; }
  .cookie-buttons { display: flex; gap: var(--space-3); flex-shrink: 0; }
  .btn-cookie { padding: 10px 20px; border-radius: 8px; font-size: 12px; font-weight: 700; cursor: pointer; border: 1px solid transparent; transition: all 0.2s; }
  .btn-cookie--primary { background: var(--color-accent); color: #fff; }
  .btn-cookie--primary:hover { transform: translateY(-1px); filter: brightness(1.1); }
  .btn-cookie--secondary { background: var(--color-bg-inset); border-color: var(--color-border); color: var(--color-text-muted); }
  .btn-cookie--secondary:hover { background: var(--color-border); color: var(--color-text-primary); }

  @media (max-width: 768px) { 
    .cookie-banner {
      bottom: 66px; /* Positioned above the mobile dock */
      margin: 0 var(--space-2) var(--space-2);
      border-radius: 16px;
      border: 1px solid var(--color-border);
      padding: var(--space-5);
    }
    .cookie-content { flex-direction: column; align-items: stretch; gap: var(--space-4); } 
    .cookie-buttons { display: flex; width: 100%; } 
    .btn-cookie { flex: 1; padding: 14px; } 
  }
</style>
