---
// src/components/ProductCard.astro — v6.0 Mobile-First 2-col Card
//
// Renders a product card for the 2-column grid.
// Product details exposed as data-pjson for overlay population.
// Visual area: gradient using seam color + large emoji (no real images).

const SEAM_COLOR: Record<string, string> = {
  crimson: 'var(--palette-red-500)',
  cobalt:  'var(--palette-navy-600)',
  jade:    'var(--palette-navy-400)',
  slate:   'var(--palette-carbon-600)',
  amber:   'var(--palette-silver-600)',
};

// Tag → CSS class mapping
function tagClass(t: string): string {
  const map: Record<string,string> = {
    fps:'fps', pro:'pro', budget:'budget', value:'value', entry:'entry',
    wireless:'wireless', lightweight:'lightweight', comfort:'comfort',
    ergonomic:'ergonomic', audiophile:'audiophile', creator:'creator',
    'hall-effect':'hall-effect'
  };
  return `tag tag--${map[t] ?? 'default'}`;
}

// Budget class for filter chips
function budgetClass(n: number): string {
  if (n <  50)  return 'under-50';
  if (n < 100)  return '50-100';
  if (n < 200)  return '100-200';
  return 'over-200';
}

// Rating from rank (rank 1 = 4.9, etc.)
function ratingFromRank(rank: number): number {
  const ratings = [4.9, 4.7, 4.5, 4.3, 4.1];
  return ratings[Math.min(rank - 1, ratings.length - 1)] ?? 4.0;
}

export interface Props {
  id:           string;
  rank:         number;
  name:         string;
  brand:        string;
  badge:        string;
  seam:         string;
  emoji:        string;
  price:        string;
  priceRaw:     number;
  msrp:         string | null;
  savings:      string | null;
  affiliate:    string;
  desc:         string;
  specs:        string[];
  pros:         string[];
  cons:         string[];
  tags:         string[];
  inStock:      boolean;
  nextDay:      boolean;
  loadoutCount: number;
  // Optional: show as full-width list card instead of grid card
  listMode?:    boolean;
}

const {
  id, rank, name, brand, badge, seam, emoji,
  price, priceRaw, msrp, savings, affiliate, desc,
  specs, pros, cons, tags, inStock, nextDay, loadoutCount,
  listMode = false,
} = Astro.props;

const seamColor  = SEAM_COLOR[seam] ?? SEAM_COLOR.slate;
const budget     = budgetClass(priceRaw);
const rating     = ratingFromRank(rank);
const isFirst    = rank === 1;

// Build rating stars string
function starsHTML(r: number): string {
  const full = Math.floor(r);
  return '★'.repeat(full) + (r % 1 >= 0.5 ? '½' : '');
}

// Build product JSON for overlay
const pjson = JSON.stringify({
  id, name, brand, price, msrp, savings,
  emoji, seam, badge, tags, specs, pros, cons,
  affiliate, inStock, nextDay, rating
});

// Tags — show max 2 on card, rest in overlay
const visibleTags = tags.slice(0, 2);
---

<article
  class:list={['pcard', isFirst && 'pcard--featured', listMode && 'pcard--list']}
  id={id}
  data-budget={budget}
  data-id={id}
  data-category={seam}
  data-pjson={pjson}
  style={`--seam-color: ${seamColor};`}
  role="article"
  aria-label={name}
  tabindex="0"
>

  <!-- Visual area -->
  <div class="pcard__visual">
    {rank === 1 && (
      <span class="pcard__rank-badge" style={`background: ${seamColor};`}>#1 Pick</span>
    )}
    {rank > 1 && (
      <span class="pcard__rank-badge" style="background: var(--color-bg-inset); color: var(--color-text-muted);">#{rank}</span>
    )}
    <div class="pcard__emoji" aria-hidden="true">{emoji}</div>
  </div>

  <!-- Card body -->
  <div class="pcard__body">

    <span class="pcard__brand" aria-hidden="true">{brand}</span>
    <h3 class="pcard__name">{name}</h3>

    <!-- Price + rating -->
    <div class="pcard__price-row">
      <span class="price-current" aria-label={`Price: ${price}`}>{price}</span>
      {savings && (
        <span class="price-badge" aria-label={`Save ${savings}`}>-{savings}</span>
      )}
    </div>

    <!-- Stars -->
    <div class="stars" aria-label={`Rating: ${rating} out of 5`}>
      <span class="stars__symbol" aria-hidden="true">{starsHTML(rating)}</span>
      <span class="stars__score">{rating.toFixed(1)}</span>
    </div>

    <!-- Tags (2 visible, rest in overlay) -->
    {visibleTags.length > 0 && (
      <div class="pcard__tags" aria-label="Tags">
        {visibleTags.map(t => (
          <span class={tagClass(t)}>{t}</span>
        ))}
        {tags.length > 2 && (
          <span class="tag" style="background: var(--color-bg-subtle); color: var(--color-text-muted); border-color: var(--color-border);">
            +{tags.length - 2}
          </span>
        )}
      </div>
    )}

    <!-- Action buttons -->
    <div class="pcard__actions">
      <button
        class="btn-wishlist"
        data-id={id}
        aria-pressed="false"
        aria-label={`Save ${name} to wishlist`}
      >
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        Save
      </button>
      <a
        href={affiliate}
        class="btn-compare"
        target="_blank"
        rel="noopener sponsored"
        data-product={id}
        data-type="card-quick"
        aria-label={`Buy ${name} on Amazon UK`}
        onclick="event.stopPropagation()"
      >
        Amazon ↗
      </a>
    </div>

  </div>

</article>

<style>
  /* List mode: horizontal layout */
  .pcard--list {
    flex-direction: row;
  }
  .pcard--list .pcard__visual {
    width: 120px;
    flex-shrink: 0;
    padding-top: 0;
    height: 120px;
  }
  .pcard--list .pcard__body {
    padding: var(--space-3) var(--space-4);
  }

  /* Keyboard focus */
  .pcard:focus-visible {
    outline: none;
    box-shadow: var(--shadow-card-hover), var(--focus-ring);
  }
</style>
