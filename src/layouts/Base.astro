---
// src/layouts/Base.astro
// The single layout shell wrapping every page on the site.
//
// Slots:
//   name="head"   → extra <head> tags (page-specific meta, schema, etc.)
//   name="hero"   → full-bleed hero section, renders above content-pad
//   (default)     → main page content, renders inside content-pad
//
// Props:
//   title         → <title> tag and og:title
//   description   → meta description and og:description
//   canonical     → canonical URL (auto-computed from Astro.url if omitted)
//   ogType        → og:type (defaults to "website", use "article" for guides/comparisons)

export interface Props {
  title:        string;
  description:  string;
  canonical?:   string;
  ogType?:      string;
  ogImage?:     string;
}
const { ogImage = 'https://stackpick.co.uk/assets/images/og-default.png' } = Astro.props;

const {
  title,
  description,
  canonical = new URL(Astro.url.pathname, Astro.site).href,
  ogType    = 'website',
} = Astro.props;

// Ensure every page title includes the brand name, but never doubles it
const metaTitle = title.includes('StackPick') ? title : `${title} | StackPick`;

// Build-time active state detection
// Astro.url.pathname is available at build time for every static route.
// We use it to set aria-current and active classes without any JavaScript.
const path = Astro.url.pathname;

// Sidebar — category pages
const isMice      = path === '/mice/' || path.startsWith('/mice/');
const isKeyboards = path === '/keyboards/' || path.startsWith('/keyboards/');
const isHeadsets  = path === '/headsets/' || path.startsWith('/headsets/');
const isMonitors  = path === '/monitors/' || path.startsWith('/monitors/');
const isChairs    = path === '/chairs/' || path.startsWith('/chairs/');

// Desktop nav — section pages
const isGuides      = path.startsWith('/guides');
const isComparisons = path.startsWith('/comparisons');
const isSearch      = path.startsWith('/search');

// Mobile dock
const isHome = path === '/';

// Active sidebar link helper
function sidebarLinkClass(active: boolean): string {
  return active ? 'sidebar-link active' : 'sidebar-link';
}
---

<!DOCTYPE html>
<html lang="en-GB" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">

  <!--
    FLASH-OF-WRONG-THEME PREVENTION
    Runs synchronously before any rendering.
    Must be is:inline so it is not deferred.
    Reads localStorage first, falls back to OS preference.
    Defaults to "light" if neither is set.
    Theme values: "light" | "dark" | "earth"
  -->
  <script is:inline>
    (function () {
      var saved  = null;
      try { saved = localStorage.getItem('sp-theme'); } catch (e) {}
      var system = (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches)
                   ? 'dark' : 'light';
      var valid  = ['light', 'dark', 'earth'];
      var theme  = (saved && valid.indexOf(saved) !== -1) ? saved : system;
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>

  <!-- ── Primary meta ── -->
  <title>{metaTitle}</title>
  <meta name="description"         content={description}>
  <meta name="robots"              content="index, follow">
  <meta name="author"              content="StackPick">
  <link rel="canonical"            href={canonical}>

  <!-- ── Open Graph ── -->
  <meta property="og:type"         content={ogType}>
  <meta property="og:title"        content={metaTitle}>
  <meta property="og:description"  content={description}>
  <meta property="og:url"          content={canonical}>
  <meta property="og:site_name"    content="StackPick">
  <meta property="og:locale"       content="en_GB">
<!-- ── Twitter / X Card ── -->
  <meta name="twitter:card"        content="summary_large_image">
  <meta name="twitter:title"       content={metaTitle}>
  <meta name="twitter:description" content={description}>
  <meta property="og:image"        content="https://stackpick.co.uk/assets/images/og-default.png">
  <meta property="og:image:width"  content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt"    content="StackPick — Best Gaming Gear for UK Gamers">

  <!-- ── PWA & mobile ── -->
  <meta name="theme-color"         content="#1B3022" media="(prefers-color-scheme: light)">
  <meta name="theme-color"         content="#0F0F0F" media="(prefers-color-scheme: dark)">
  <meta name="mobile-web-app-capable"              content="yes">
  <meta name="apple-mobile-web-app-capable"        content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title"          content="StackPick">
  <link rel="manifest"             href="/manifest.json">

  <!-- ── Favicon — inline SVG, no external request ── -->
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%231B3022'/><text y='72' x='50' text-anchor='middle' font-size='60' font-family='system-ui' font-weight='900' fill='%23D95433'>S</text></svg>">

  <!-- ── Font loading ──
    Syne:           Display headings — geometric, memorable, brand character
    Inter:          Body — maximum legibility at all sizes
    JetBrains Mono: Spec labels, prices, metadata — technical precision
    display=swap ensures text is visible during font load.
    preconnect eliminates DNS + TLS negotiation cost.
  -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap"
    rel="stylesheet"
  >

  <!-- ── Stylesheets — strict load order ── -->
  <link rel="stylesheet" href="/assets/css/tokens.css">
  <link rel="stylesheet" href="/assets/css/components.css">
  <link rel="stylesheet" href="/assets/css/style.css">
  
  <!-- ── Google Analytics 4 ── -->
  <!-- gtag.js bootstrap — must load before analytics.js -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-ZTN7H3L6DV"></script>
  <!-- Site analytics: affiliate clicks, scroll depth, LCP, error tracking -->
  <script src="/assets/js/analytics.js" defer></script>


  <!-- ── Per-page head injection ── -->
  <slot name="head" />
</head>

<body class="streetwear-layout">

  <!-- ── Skip link — keyboard accessibility ── -->
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <!-- ════════════════════════════════════════════════════════
       DESKTOP HEADER
       Fixed top bar. Hidden on mobile (≥1024px breakpoint).
       Contains: logo wordmark | primary nav | theme toggle
       ════════════════════════════════════════════════════════ -->
  <header class="desktop-header" role="banner">
    <div class="header-grid">

      <!-- Logo wordmark -->
      <a href="/" class="logo" aria-label="StackPick — back to homepage">
        STACK<span>·</span>PICK
      </a>

      <!-- Primary navigation -->
      <nav class="desktop-nav" aria-label="Main navigation">
        <a
          href="/guides/"
          aria-current={isGuides ? 'page' : undefined}
        >Guides</a>
        <a
          href="/comparisons/"
          aria-current={isComparisons ? 'page' : undefined}
        >Compare</a>
        <a
          href="/search/"
          aria-current={isSearch ? 'page' : undefined}
        >Search</a>
        <a href="/about/">About</a>
      </nav>

      <!-- Theme toggle -->
      <div class="header-actions">
        <button
          class="theme-toggle"
          id="theme-toggle-desktop"
          aria-label="Switch theme"
          title="Switch theme"
        >
          <span class="icon" aria-hidden="true" id="theme-icon-desktop">
            <!-- Icon updated by theme.js after load -->
            ◑
          </span>
        </button>
      </div>

    </div>
  </header>

  <!-- ════════════════════════════════════════════════════════
       PAGE SHELL
       On mobile: single stacked column.
       On desktop: sidebar rail left + main content right.
       Max-width and padding handled by .site-container
       in components.css and style.css.
       ════════════════════════════════════════════════════════ -->
  <div class="site-container">

    <!-- ── Sidebar — desktop only (hidden via CSS on mobile) ── -->
    <aside class="sidebar" aria-label="Category navigation">
      <div class="sidebar-inner">

        <!-- Sidebar logo — shown only on desktop -->
        <a href="/" class="logo" aria-label="StackPick homepage">
          STACK<span>·</span>PICK
        </a>

        <!-- Hardware categories -->
        <div class="sidebar-group">
          <p class="label">Hardware</p>
          <nav aria-label="Browse by hardware category">
            <a
              href="/mice/"
              class={sidebarLinkClass(isMice)}
              aria-current={isMice ? 'page' : undefined}
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5" y="2" width="14" height="20" rx="7"/><path d="M12 2v8"/></svg>
              Mice
            </a>
            <a
              href="/keyboards/"
              class={sidebarLinkClass(isKeyboards)}
              aria-current={isKeyboards ? 'page' : undefined}
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M6 11h.01M9 11h.01M12 11h.01M15 11h.01M18 11h.01M6 15h12"/></svg>
              Keyboards
            </a>
            <a
              href="/headsets/"
              class={sidebarLinkClass(isHeadsets)}
              aria-current={isHeadsets ? 'page' : undefined}
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 14h2a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-7a9 9 0 0 1 18 0v7a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h2"/></svg>
              Headsets
            </a>
            <a
              href="/monitors/"
              class={sidebarLinkClass(isMonitors)}
              aria-current={isMonitors ? 'page' : undefined}
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
              Monitors
            </a>
            <a
              href="/chairs/"
              class={sidebarLinkClass(isChairs)}
              aria-current={isChairs ? 'page' : undefined}
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2v6M18 2v6M6 8h12M8 22v-4M16 22v-4M6 14h12a2 2 0 0 0 2-2V8H4v4a2 2 0 0 0 2 2z"/></svg>
              Chairs
            </a>
          </nav>
        </div>

        <!-- Editorial sections -->
        <div class="sidebar-group">
          <p class="label">Editorial</p>
          <nav aria-label="Browse editorial content">
            <a
              href="/guides/"
              class={sidebarLinkClass(isGuides)}
              aria-current={isGuides ? 'page' : undefined}
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
              Setup Guides
            </a>
            <a
              href="/comparisons/"
              class={sidebarLinkClass(isComparisons)}
              aria-current={isComparisons ? 'page' : undefined}
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
              Comparisons
            </a>
          </nav>
        </div>

        <!-- Sidebar theme toggle -->
        <div class="sidebar-group">
          <button
            class="theme-toggle"
            id="theme-toggle-sidebar"
            aria-label="Switch theme"
            style="width: 100%; justify-content: flex-start; gap: var(--space-2); padding: var(--space-2) var(--space-3);"
          >
            <span class="icon" aria-hidden="true" id="theme-icon-sidebar">◑</span>
            <span id="sidebar-theme-label" style="font-size: var(--text-sm); font-weight: var(--weight-medium); color: var(--color-text-secondary);">Theme</span>
          </button>
        </div>

      </div>
    </aside>

    <!-- ── Main content area ── -->
    <main class="main-content" id="main-content" tabindex="-1">

      <!-- Hero slot — full bleed, no padding wrapper -->
      <slot name="hero" />

      <!-- Default slot — wrapped in padding container -->
      <div class="content-pad">
        <slot />
      </div>

    </main>
  </div>

  <!-- ════════════════════════════════════════════════════════
       FOOTER
       ════════════════════════════════════════════════════════ -->
  <footer class="site-footer" role="contentinfo">
    <div class="site-footer__inner">

      <div>
        <a href="/" class="site-footer__brand" aria-label="StackPick homepage">
          STACK<span>·</span>PICK
        </a>
      </div>

      <p class="site-footer__copy">
        Researched gaming gear for UK gamers. Amazon UK affiliate links —
        <a href="/about/#disclosure">disclosure</a>.
        &copy; {new Date().getFullYear()} StackPick. All prices verified weekly.
      </p>

    </div>
  </footer>

  <!-- ════════════════════════════════════════════════════════
       MOBILE BOTTOM TAB BAR
       Fixed. Always visible on mobile. Hidden on desktop.
       Active state set at build time via pathname.
       "More" active state managed by JS when overlay opens.
       ════════════════════════════════════════════════════════ -->
  <nav class="mobile-dock" aria-label="Mobile navigation">
    <div class="dock-container">

      <!-- Home -->
      <a
        href="/"
        class:list={['dock-item', isHome && 'active']}
        aria-current={isHome ? 'page' : undefined}
        aria-label="Home"
      >
        <svg class="dock-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        <span class="dock-label">Home</span>
      </a>

      <!-- Search -->
      <a
        href="/search/"
        class:list={['dock-item', isSearch && 'active']}
        aria-current={isSearch ? 'page' : undefined}
        aria-label="Search"
      >
        <svg class="dock-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <span class="dock-label">Search</span>
      </a>

      <!-- Centre hub — Guides CTA -->
      <div class="dock-brand-center">
        <a
          href="/guides/"
          class="dock-cta"
          aria-label="Setup guides"
        >
          PICK
        </a>
      </div>

      <!-- Compare -->
      <a
        href="/comparisons/"
        class:list={['dock-item', isComparisons && 'active']}
        aria-current={isComparisons ? 'page' : undefined}
        aria-label="Compare gear"
      >
        <svg class="dock-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="20" x2="18" y2="10"/>
          <line x1="12" y1="20" x2="12" y2="4"/>
          <line x1="6" y1="20" x2="6" y2="14"/>
        </svg>
        <span class="dock-label">Compare</span>
      </a>

      <!-- More — triggers overlay -->
      <button
        class="dock-item"
        id="more-btn"
        aria-label="More navigation options"
        aria-expanded="false"
        aria-controls="more-panel"
      >
        <svg class="dock-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="5" cy="12" r="1.5" fill="currentColor"/>
          <circle cx="12" cy="12" r="1.5" fill="currentColor"/>
          <circle cx="19" cy="12" r="1.5" fill="currentColor"/>
        </svg>
        <span class="dock-label">More</span>
      </button>

    </div>
  </nav>

  <!-- ════════════════════════════════════════════════════════
       MOBILE MORE OVERLAY
       Full-screen panel triggered by the "More" dock item.
       Contains secondary nav + theme switcher.
       ════════════════════════════════════════════════════════ -->
  <div
    class="more-overlay"
    id="more-panel"
    role="dialog"
    aria-label="More navigation options"
    aria-modal="true"
    aria-hidden="true"
  >

    <!-- Close button -->
    <button
      class="close-overlay"
      id="close-more"
      aria-label="Close menu"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <div class="overlay-content">

      <!-- Hardware section -->
      <p class="overlay-heading">Hardware</p>
      <div class="overlay-grid">
        <a href="/mice/">Mice</a>
        <a href="/keyboards/">Keyboards</a>
        <a href="/headsets/">Headsets</a>
        <a href="/monitors/">Monitors</a>
        <a href="/chairs/">Chairs</a>
        <a href="/search/">Search</a>
      </div>

      <!-- System section -->
      <p class="overlay-heading">Picks</p>
      <div class="overlay-grid">
        <a href="/guides/">Setup Guides</a>
        <a href="/comparisons/">Comparisons</a>
        <a href="/about/">About</a>
        <!-- Theme cycle button -->
        <button
          id="theme-cycle-btn"
          class="theme-pill"
          aria-label="Switch colour theme"
        >
          <span id="theme-cycle-label">Theme: Light</span>
        </button>
      </div>

    </div>
  </div>

  <!-- ════════════════════════════════════════════════════════
       INLINE SCRIPTS
       Vanilla JS only. No dependencies.
       Executed after the DOM is parsed.
       ════════════════════════════════════════════════════════ -->
  <script>
    // ── 01 MOBILE OVERLAY — open / close ────────────────────
    const moreBtn   = document.getElementById('more-btn')   as HTMLButtonElement | null;
    const closeMore = document.getElementById('close-more') as HTMLButtonElement | null;
    const morePanel = document.getElementById('more-panel') as HTMLElement | null;
    const body      = document.body;

    function openOverlay(): void {
      if (!morePanel || !moreBtn) return;
      morePanel.classList.add('open');
      morePanel.setAttribute('aria-hidden', 'false');
      moreBtn.setAttribute('aria-expanded', 'true');
      moreBtn.classList.add('active');
      body.style.overflow = 'hidden'; // Prevent background scroll
    }

    function closeOverlay(): void {
      if (!morePanel || !moreBtn) return;
      morePanel.classList.remove('open');
      morePanel.setAttribute('aria-hidden', 'true');
      moreBtn.setAttribute('aria-expanded', 'false');
      moreBtn.classList.remove('active');
      body.style.overflow = '';
    }

    moreBtn?.addEventListener('click', openOverlay);
    closeMore?.addEventListener('click', closeOverlay);

    // Close on overlay backdrop click (clicking outside the content)
    morePanel?.addEventListener('click', (e: MouseEvent) => {
      if (e.target === morePanel) closeOverlay();
    });

    // Close on Escape key
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape' && morePanel?.classList.contains('open')) {
        closeOverlay();
        moreBtn?.focus(); // Return focus to trigger
      }
    });

    // ── 02 THEME SYSTEM ─────────────────────────────────────
    // Three themes: light → dark → earth → light (cycles)
    // Saved to localStorage. Respects OS on first visit.
    // Applies .theme-transitioning to animate surface changes.

    const THEMES     = ['light', 'dark', 'earth'] as const;
    const THEME_LABELS: Record<string, string> = {
      light: 'Theme: Light',
      dark:  'Theme: Dark',
      earth: 'Theme: Earth',
    };
    const THEME_ICONS: Record<string, string> = {
      light: '☀',
      dark:  '◑',
      earth: '◈',
    };

    function getSavedTheme(): string | null {
      try { return localStorage.getItem('sp-theme'); } catch { return null; }
    }

    function saveTheme(theme: string): void {
      try { localStorage.setItem('sp-theme', theme); } catch { /* noop */ }
    }

    function applyTheme(theme: string): void {
      const html = document.documentElement;

      // Apply transition class for smooth surface swap
      html.classList.add('theme-transitioning');
      html.setAttribute('data-theme', theme);

      // Remove transition class after animation completes
      setTimeout(() => html.classList.remove('theme-transitioning'), 350);

      // Update all theme toggle icons
      const icon  = THEME_ICONS[theme]  ?? '◑';
      const label = THEME_LABELS[theme] ?? 'Switch theme';

      document.querySelectorAll<HTMLElement>('.theme-toggle').forEach(btn => {
        const iconEl = btn.querySelector<HTMLElement>('#theme-icon-desktop, #theme-icon-sidebar');
        if (iconEl) iconEl.textContent = icon;
        else {
          const iconFallback = btn.querySelector<HTMLElement>('.icon');
          if (iconFallback) iconFallback.textContent = icon;
        }
        btn.setAttribute('aria-label', `Switch theme (currently ${theme})`);
      });

      // Update sidebar label
      const sidebarLabel = document.getElementById('sidebar-theme-label');
      if (sidebarLabel) {
        sidebarLabel.textContent = theme.charAt(0).toUpperCase() + theme.slice(1);
      }

      // Update overlay cycle button
      const cycleLabel = document.getElementById('theme-cycle-label');
      if (cycleLabel) cycleLabel.textContent = label;
    }

    function cycleTheme(): void {
      const current = document.documentElement.getAttribute('data-theme') ?? 'light';
      const idx     = THEMES.indexOf(current as typeof THEMES[number]);
      const next    = THEMES[(idx + 1) % THEMES.length];
      applyTheme(next);
      saveTheme(next);
    }

    // Wire up all theme controls
    document.querySelectorAll<HTMLElement>('.theme-toggle, #theme-cycle-btn').forEach(btn => {
      btn.addEventListener('click', cycleTheme);
    });

    // Sync initial UI state with the theme already applied by the inline script
    const initialTheme = document.documentElement.getAttribute('data-theme') ?? 'light';
    applyTheme(initialTheme);

    // Follow OS preference changes when no saved preference
    window.matchMedia?.('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
      if (!getSavedTheme()) applyTheme(e.matches ? 'dark' : 'light');
    });

    // ── 03 ACTIVE SIDEBAR LINK — runtime refinement ──────────
    // Build-time active states handle the main cases.
    // This catches edge cases like /guides/some-slug/ where
    // the sidebar "Setup Guides" link should still be active.
    (function setActiveSidebarLinks(): void {
      const currentPath = window.location.pathname;
      document.querySelectorAll<HTMLAnchorElement>('.sidebar-link, .desktop-nav a').forEach(link => {
        const href = link.getAttribute('href') ?? '';
        if (href.length > 1 && currentPath.startsWith(href)) {
          link.classList.add('active');
          link.setAttribute('aria-current', 'page');
        }
      });
    })();

    // ── 04 SERVICE WORKER REGISTRATION ──────────────────────
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js').catch(() => { /* noop */ });
      });
    }
  </script>

</body>
