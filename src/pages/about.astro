---
// src/pages/about.astro — v6.0
// About page: mission statement, research policy, and affiliate disclosure

import Base from '../layouts/Base.astro';

const BUILD_MONTH = new Date().toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
---

<Base
  title="About StackPick | UK Gaming Gear Research"
  description="How StackPick researches and recommends gaming gear for UK gamers. Affiliate disclosure and editorial policy."
  canonical="https://stackpick.co.uk/about/"
>
  <section slot="hero" class="hero hero--inner">
    <div class="hero-container container">
      <p class="hero-eyebrow">Mission Statement</p>
      <h1>About StackPick</h1>
      <p>Independent research for UK gamers. Real prices. Zero filler. Verified for {BUILD_MONTH}.</p>
    </div>
  </section>

  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="container">
      <ol class="breadcrumb-list">
        <li><a href="/">Home</a></li>
        <li class="breadcrumb-sep" aria-hidden="true">/</li>
        <li aria-current="page">About</li>
      </ol>
    </div>
  </nav>

  <section class="section container">
    <div class="buying-guide">

      <div class="about-grid">
        <div class="about-main">
          <h2>What StackPick Is</h2>
          <p>StackPick is the definitive UK gaming gear database. Our mission is simple: cut through the marketing noise and tell you what to actually buy — with real reasoning, verified UK pricing, and no fluff.</p>
          <p>Every category page, buying guide, and comparison exists to answer one question: <strong>Given your budget and use case, what is the right piece of kit?</strong> Not the most-marketed. Not the one with the biggest RGB. The right one.</p>

          <h2>How We Research</h2>
          <p>Every recommendation starts with the data — sensor specs, switch actuation profiles, panel response times, and weight-to-feature ratios. Then it gets filtered through what actually matters in real use: how a mouse feels after three hours of Valorant, whether a chair's lumbar support holds up over a full work day, or whether a monitor's HDR implementation is genuine or marketing.</p>
          <p>We cross-reference UK community consensus from Reddit, Discord, and long-term owner reviews. We track price history. We do not recommend products that are only "good value" when they happen to be on sale — the price you see is the price we based the call on, checked and updated weekly.</p>
          <p>When a newer product makes a current recommendation obsolete, we update the page. When a price shift changes the value calculus, we note it. The date on every page is the date it was last verified — not the date it was first published.</p>

          <h2 id="disclosure">Affiliate Disclosure</h2>
          <p>StackPick participates in the Amazon Associates programme. Every product link on this site is an Amazon UK affiliate link — if you buy through one, we receive a small commission at no extra cost to you.</p>
          <p>This is how the site is funded. It does not influence which products are recommended. The affiliate relationship is with Amazon, not with the brands — we have no sponsored content deals, no paid placements, and no agreements with manufacturers. A product earns a recommendation by being the best option at its price. That is the only criterion.</p>
        </div>

        <aside class="about-sidebar">
          <div class="callout">
            <p class="callout__title">Our Promise</p>
            <p>No fake reviews. No inflated specs used to justify bad picks. No recommending the expensive option when the cheaper one is genuinely better for the use case. The goal is to give you the same advice a knowledgeable friend would — the one who has actually used the gear and has no reason to steer you wrong.</p>
          </div>

          <div class="about-stats">
            <div class="stat-card">
              <span class="stat-value">100%</span>
              <span class="stat-label">Independent</span>
            </div>
            <div class="stat-card">
              <span class="stat-value">UK</span>
              <span class="stat-label">Market Focused</span>
            </div>
            <div class="stat-card">
              <span class="stat-value">Weekly</span>
              <span class="stat-label">Price Verification</span>
            </div>
          </div>
        </aside>
      </div>

      <div class="about-footer">
        <p class="last-updated">Editorial Policy Last Verified: {BUILD_MONTH}</p>
      </div>

    </div>
  </section>

  <style>
    .about-grid { display: grid; grid-template-columns: 1fr 320px; gap: var(--space-12); align-items: start; }
    .about-sidebar { position: sticky; top: 100px; display: flex; flex-direction: column; gap: var(--space-6); }
    
    .about-stats { display: grid; grid-template-columns: 1fr; gap: var(--space-4); margin-top: var(--space-4); }
    .stat-card { background: var(--color-bg-inset); border: 1px solid var(--color-border); padding: var(--space-6); border-radius: 16px; text-align: center; }
    .stat-value { display: block; font-family: var(--font-display); font-size: var(--text-3xl); font-weight: 900; color: var(--color-accent); margin-bottom: 4px; }
    .stat-label { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-text-dim); }

    .about-footer { margin-top: var(--space-16); padding-top: var(--space-8); border-top: 1px solid var(--color-border); }
    .last-updated { font-size: 11px; font-weight: 700; color: var(--color-text-dim); text-transform: uppercase; letter-spacing: 0.05em; }

    @media (max-width: 968px) {
      .about-grid { grid-template-columns: 1fr; }
      .about-sidebar { position: static; }
    }
  </style>
</Base>
