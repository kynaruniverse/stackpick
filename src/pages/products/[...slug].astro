---
// src/pages/products/[...slug].astro — v6.0
// Dedicated product pages: /products/razer-viper-v3-pro/

import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { SEAM_COLOR, ratingFromRank } from '../../lib/productUtils';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const rating = ratingFromRank(entry.data.rank ?? 3);
const starsStr = '★'.repeat(Math.floor(rating)) + (rating % 1 >= 0.5 ? '½' : '');
const seamColor = SEAM_COLOR[entry.data.seam] ?? 'var(--color-accent)';

const BUILD_MONTH = new Date().toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
const BUILD_SHORT = new Date().toLocaleDateString('en-GB', { month: 'short', year: 'numeric' });
---

<Base 
  title={`${entry.data.name} UK Review & Best Price ${new Date().getFullYear()} | StackPick`} 
  description={`${entry.data.name} review for UK gamers. ${entry.data.badge} — verified UK pricing and availability.`}
  canonical={`https://stackpick.co.uk/products/${entry.slug}/`}
  ogType="product"
>
  <main class="product-page container" id="main-content">
    <nav class="breadcrumb-bar" aria-label="Breadcrumb">
      <ol class="breadcrumb-list">
        <li><a href="/">Home</a></li>
        <li class="breadcrumb-sep" aria-hidden="true">/</li>
        <li><a href="/hardware/">Hardware</a></li>
        <li class="breadcrumb-sep" aria-hidden="true">/</li>
        <li><a href={`/${entry.data.category}/`}>{entry.data.category.charAt(0).toUpperCase() + entry.data.category.slice(1)}</a></li>
        <li class="breadcrumb-sep" aria-hidden="true">/</li>
        <li aria-current="page">{entry.data.name}</li>
      </ol>
    </nav>

    <div class="product-grid-layout" style={`--seam-color: ${seamColor};`}>
      <!-- Left: Visual -->
      <div class="product-visual">
        <div class="product-emoji" aria-hidden="true">{entry.data.emoji}</div>
        <div class="product-rating">
          <div class="stars" aria-label={`Rating: ${rating.toFixed(1)} out of 5`}>
            <span class="stars__symbol">{starsStr}</span>
            <span class="stars__score">{rating.toFixed(1)}</span>
          </div>
          <span class="score-label">StackPick Verified Pick</span>
        </div>
      </div>

      <!-- Right: Info -->
      <div class="product-info">
        <div class="product-header">
          <span class="brand-tag">{entry.data.brand}</span>
          <h1>{entry.data.name}</h1>
          <p class="hero-subtitle">{entry.data.badge}</p>
        </div>

        <div class="price-box">
          <div class="price-main">
            <span class="price-current">{entry.data.price}</span>
            <div class="price-meta">
              {entry.data.msrp && <span class="price-msrp">MSRP: {entry.data.msrp}</span>}
              <span class="verified-badge">Price Verified {BUILD_SHORT}</span>
            </div>
          </div>
          {entry.data.savings && <div class="savings-badge">Save {entry.data.savings}</div>}
        </div>

        <div class="action-grid">
          <a href={entry.data.affiliate} class="btn-primary btn-xl" target="_blank" rel="noopener sponsored">
            View on Amazon UK
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
          </a>
          <button class="btn-secondary btn-xl btn-wishlist" data-id={entry.data.id} aria-pressed="false">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            Save
          </button>
        </div>

        <div class="prose-content">
          <Content />
        </div>

        <div class="specs-grid">
          <div class="specs-col">
            <h3>Pros</h3>
            <ul class="pros-cons__list">
              {entry.data.pros.map(p => <li class="pros-cons__item pros-cons__item--pro">✓ {p}</li>)}
            </ul>
          </div>
          <div class="specs-col">
            <h3>Cons</h3>
            <ul class="pros-cons__list">
              {entry.data.cons.map(c => <li class="pros-cons__item pros-cons__item--con">✗ {c}</li>)}
            </ul>
          </div>
        </div>

        <div class="product-footer">
          <p class="last-updated">Information verified: {BUILD_MONTH}</p>
          <p class="affiliate-notice">As an Amazon Associate, StackPick earns from qualifying purchases at no extra cost to you.</p>
        </div>
      </div>
    </div>
  </main>
</Base>

<style>
  .product-page { padding-bottom: var(--space-16); }
  
  .product-grid-layout { 
    display: grid; 
    grid-template-columns: 1fr 1fr; 
    gap: var(--space-12); 
    align-items: start; 
    margin-top: var(--space-8);
  }
  
  .product-visual { 
    background: var(--color-bg-inset); 
    border: 1px solid var(--color-border); 
    border-radius: 32px; 
    aspect-ratio: 1; 
    display: flex; 
    flex-direction: column; 
    align-items: center; 
    justify-content: center; 
    position: sticky; 
    top: 100px; 
    box-shadow: var(--shadow-sm);
  }
  
  .product-emoji { font-size: 140px; filter: drop-shadow(0 20px 40px rgba(0,0,0,0.15)); }
  
  .product-rating { margin-top: var(--space-8); text-align: center; }
  .product-rating .stars { display: flex; align-items: baseline; justify-content: center; gap: 8px; margin-bottom: 4px; }
  .product-rating .stars__symbol { font-size: 24px; color: var(--color-accent); }
  .product-rating .stars__score { font-family: var(--font-mono); font-weight: 800; font-size: 20px; color: var(--color-text-primary); }
  .score-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 800; color: var(--color-text-dim); }

  .brand-tag { font-family: var(--font-mono); font-size: 11px; font-weight: 800; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.15em; }
  h1 { font-size: 56px; font-weight: 900; line-height: 1.05; margin: var(--space-2) 0; letter-spacing: -0.03em; color: var(--color-text-primary); }
  .hero-subtitle { font-size: 20px; color: var(--color-text-muted); margin-bottom: var(--space-8); line-height: 1.4; }

  .price-box { 
    background: var(--color-bg-card); 
    border: 1px solid var(--color-border); 
    padding: var(--space-6) var(--space-8); 
    border-radius: 24px; 
    margin-bottom: var(--space-8); 
    display: flex; 
    justify-content: space-between;
    align-items: center;
    border-left: 6px solid var(--seam-color);
  }
  
  .price-main { display: flex; align-items: center; gap: var(--space-4); }
  .price-current { font-family: var(--font-mono); font-size: 48px; font-weight: 900; letter-spacing: -0.04em; color: var(--color-text-primary); }
  
  .price-meta { display: flex; flex-direction: column; gap: 2px; }
  .price-msrp { font-size: 12px; color: var(--color-text-dim); text-decoration: line-through; }
  .verified-badge { font-size: 9px; font-weight: 800; color: #10b981; text-transform: uppercase; letter-spacing: 0.05em; background: rgba(16, 185, 129, 0.1); padding: 4px 8px; border-radius: 6px; }

  .savings-badge { background: var(--color-accent); color: #fff; padding: 6px 12px; border-radius: 999px; font-size: 12px; font-weight: 800; text-transform: uppercase; }

  .action-grid { display: grid; grid-template-columns: 2fr 1fr; gap: var(--space-4); margin-bottom: var(--space-10); }
  .btn-xl { height: 72px; border-radius: 20px; font-size: 16px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; display: flex; align-items: center; justify-content: center; gap: 12px; text-decoration: none; transition: all 0.2s; }
  .btn-primary:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(200, 32, 32, 0.2); }
  .btn-secondary:hover { background: var(--color-bg-subtle); }

  .prose-content { font-size: 18px; line-height: 1.7; color: var(--color-text-muted); margin-bottom: var(--space-12); }
  .prose-content :global(p) { margin-bottom: var(--space-6); }
  .prose-content :global(strong) { color: var(--color-text-primary); font-weight: 800; }
  
  .specs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-8); border-top: 1px solid var(--color-border); padding-top: var(--space-10); }
  .specs-col h3 { font-size: 11px; text-transform: uppercase; letter-spacing: 0.15em; font-weight: 800; color: var(--color-text-dim); margin-bottom: var(--space-6); }
  
  .pros-cons__list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 12px; }
  .pros-cons__item { font-size: 15px; font-weight: 600; line-height: 1.4; }
  .pros-cons__item--pro { color: #10b981; }
  .pros-cons__item--con { color: var(--color-accent); }

  .product-footer { margin-top: var(--space-16); padding-top: var(--space-8); border-top: 1px solid var(--color-border); }
  .last-updated { font-size: 11px; font-weight: 700; color: var(--color-text-dim); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px; }
  .affiliate-notice { font-size: 11px; color: var(--color-text-dim); font-style: italic; }

  @media (max-width: 968px) {
    .product-grid-layout { grid-template-columns: 1fr; gap: var(--space-8); }
    .product-visual { position: static; aspect-ratio: 1/1; width: 100%; max-width: 500px; margin: 0 auto; }
    h1 { font-size: 40px; }
    .action-grid { grid-template-columns: 1fr; }
    .price-current { font-size: 40px; }
  }
</style>
