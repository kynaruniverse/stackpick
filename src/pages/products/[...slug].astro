---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Helper for stars
function starsHTML(r: number): string {
  const full = Math.floor(r);
  return '★'.repeat(full) + (r % 1 >= 0.5 ? '½' : '');
}
---

<Base 
  title={`${entry.data.name} — StackPick`} 
  description={entry.data.badge}
>
  <main class="product-page container" id="main-content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <a href={`/${entry.data.category}/`}>{entry.data.category.charAt(0).toUpperCase() + entry.data.category.slice(1)}</a>
      <span class="sep">/</span>
      <span class="current">{entry.data.name}</span>
    </nav>

    <div class="product-grid-layout">
      <!-- Left: Visual -->
      <div class="product-visual">
        <div class="product-emoji" aria-hidden="true">{entry.data.emoji}</div>
        <div class="product-rating">
          <span class="stars">{starsHTML(entry.data.priceRaw / 40 > 5 ? 5 : 4.5)}</span>
          <span class="score">StackPick Verified</span>
        </div>
      </div>

      <!-- Right: Info -->
      <div class="product-info">
        <span class="brand">{entry.data.brand}</span>
        <h1>{entry.data.name}</h1>
        <p class="badge-text">{entry.data.badge}</p>

        <div class="price-box">
          <div class="price-main">
            <span class="currency">£</span>
            <span class="amount">{entry.data.priceRaw}</span>
          </div>
          <div class="price-meta">
            {entry.data.msrp && <span class="msrp">MSRP: {entry.data.msrp}</span>}
            <span class="verified-tag">Verified UK Price</span>
          </div>
        </div>

        <div class="action-bar">
          <a href={entry.data.affiliate} class="btn-primary" target="_blank" rel="noopener sponsored">
            View on Amazon UK ↗
          </a>
          <button class="btn-secondary" data-id={entry.data.id} id="add-to-wishlist">
            Save to Wishlist
          </button>
        </div>

        <div class="prose-content">
          <Content />
        </div>

        <div class="specs-grid">
          <div class="specs-col">
            <h3>Pros</h3>
            <ul class="pros-list">
              {entry.data.pros.map(p => <li>✓ {p}</li>)}
            </ul>
          </div>
          <div class="specs-col">
            <h3>Cons</h3>
            <ul class="cons-list">
              {entry.data.cons.map(c => <li>✗ {c}</li>)}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </main>
</Base>

<style>
  .product-page { padding-top: var(--space-8); padding-bottom: var(--space-12); }
  .breadcrumb { display: flex; gap: var(--space-2); font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-dim); margin-bottom: var(--space-8); }
  .breadcrumb a { color: var(--color-text-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-accent); }
  .breadcrumb .sep { color: var(--color-border); }
  
  .product-grid-layout { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-12); align-items: start; }
  
  .product-visual { background: var(--color-bg-inset); border: 1px solid var(--color-border); border-radius: 24px; aspect-ratio: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; position: sticky; top: 100px; }
  .product-emoji { font-size: 120px; filter: drop-shadow(0 20px 40px rgba(0,0,0,0.2)); }
  .product-rating { margin-top: var(--space-8); text-align: center; }
  .product-rating .stars { display: block; font-size: 24px; color: var(--color-accent); margin-bottom: 4px; }
  .product-rating .score { font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-text-dim); }

  .brand { font-size: var(--size-sm); font-weight: var(--weight-bold); color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.1em; }
  h1 { font-size: 48px; font-weight: 900; line-height: 1.1; margin: var(--space-2) 0; letter-spacing: -0.02em; }
  .badge-text { font-size: var(--size-lg); color: var(--color-text-muted); margin-bottom: var(--space-6); }

  .price-box { background: var(--color-bg-card); border: 1px solid var(--color-border); padding: var(--space-6); border-radius: 16px; margin-bottom: var(--space-8); display: flex; align-items: center; gap: var(--space-6); }
  .price-main { display: flex; align-items: flex-start; line-height: 1; }
  .price-main .currency { font-size: 24px; font-weight: 700; margin-top: 4px; }
  .price-main .amount { font-size: 56px; font-weight: 900; letter-spacing: -0.04em; }
  .price-meta { display: flex; flex-direction: column; gap: 4px; }
  .msrp { font-size: 12px; color: var(--color-text-dim); text-decoration: line-through; }
  .verified-tag { font-size: 10px; font-weight: 700; color: #10b981; text-transform: uppercase; background: rgba(16, 185, 129, 0.1); padding: 4px 8px; border-radius: 4px; }

  .action-bar { display: flex; gap: var(--space-4); margin-bottom: var(--space-8); }
  .btn-primary { flex: 2; text-align: center; padding: 18px; font-size: 16px; font-weight: 800; background: var(--color-accent); color: #fff; border-radius: 12px; text-decoration: none; transition: transform 0.2s; }
  .btn-primary:hover { transform: translateY(-2px); }
  .btn-secondary { flex: 1; padding: 18px; font-size: 14px; font-weight: 700; background: var(--color-bg-inset); border: 1px solid var(--color-border); color: var(--color-text-primary); border-radius: 12px; cursor: pointer; }

  .prose-content { font-size: 18px; line-height: 1.6; color: var(--color-text-muted); margin-bottom: var(--space-10); }
  
  .specs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-6); border-top: 1px solid var(--color-border); padding-top: var(--space-8); }
  .specs-col h3 { font-size: 12px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-text-dim); margin-bottom: var(--space-4); }
  .specs-col ul { list-style: none; padding: 0; }
  .specs-col li { font-size: 14px; margin-bottom: 8px; color: var(--color-text-muted); }
  .pros-list li { color: #10b981; }
  .cons-list li { color: var(--color-accent); }

  @media (max-width: 968px) {
    .product-grid-layout { grid-template-columns: 1fr; }
    .product-visual { position: static; aspect-ratio: 16/9; }
    h1 { font-size: 32px; }
  }
</style>
