---
// src/pages/[category]/index.astro — v6.0
// Category pages: /mice/ /keyboards/ /headsets/ /monitors/ /chairs/ /controllers/ /streaming/ /desk-accessories/

import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ProductCard from '../../components/ProductCard.astro';

const BUILD_MONTH = new Date().toLocaleDateString('en-GB', { month: 'long',  year: 'numeric' });
const BUILD_SHORT = new Date().toLocaleDateString('en-GB', { month: 'short', year: 'numeric' });

type CategoryKey = 'mice' | 'keyboards' | 'headsets' | 'monitors' | 'chairs' | 'controllers' | 'streaming' | 'desk-accessories';

const CATEGORY_META: Record<CategoryKey, {
  emoji: string;
  pageTitle: string;
  metaDescription: string;
  heroTitle: string;
  heroSubtitle: string;
  breadcrumbLabel: string;
  buyingGuide: string;
}> = {
  mice: {
    emoji: '🖱️',
    pageTitle: `Best Gaming Mice UK ${new Date().getFullYear()} | StackPick`,
    metaDescription: 'Best gaming mice for UK gamers. From sub-40g super-clones to the 8K polling pros use. Verified UK pricing.',
    heroTitle: 'Best Gaming Mice (UK)',
    heroSubtitle: `From sub-40g super-clones to the 8K polling pros use. Updated ${BUILD_SHORT}.`,
    breadcrumbLabel: 'Gaming Mice',
    buyingGuide: `
      <h2>The 2026 Mouse Guide</h2>
      <h3>Polling Rate: 1K vs 4K vs 8K</h3>
      <p>Standard mice report to your PC 1,000 times per second (1K). In 2026, <strong>4K and 8K polling</strong> report up to 8,000 times. On a 240Hz or 360Hz monitor, this makes mouse movement look significantly smoother and reduces input lag by microseconds.</p>
      <h3>Optical vs Mechanical Switches</h3>
      <p>Legacy mechanical switches eventually wear out and double-click. <strong>Optical switches</strong> (like Razer's Gen-3 or Logitech's Lightforce) use a beam of light to register clicks. They are faster and effectively impossible to break.</p>
      <p class="last-updated"><em>Last updated: ${BUILD_MONTH}. Prices checked weekly.</em></p>
    `,
  },
  keyboards: {
    emoji: '⌨️',
    pageTitle: `Best Gaming Keyboards UK ${new Date().getFullYear()} | StackPick`,
    metaDescription: 'Best gaming keyboards for UK gamers. Hall Effect, wireless, and budget mechanical picks — verified UK pricing on Amazon.',
    heroTitle: 'Best Gaming Keyboards (UK)',
    heroSubtitle: `Hall Effect, wireless, and budget mechanical picks. Updated ${BUILD_SHORT}.`,
    breadcrumbLabel: 'Gaming Keyboards',
    buyingGuide: `
      <h2>The 2026 Keyboard Guide</h2>
      <h3>What is Rapid Trigger?</h3>
      <p>Standard keyboards actuate at a fixed point. <strong>Hall Effect (HE)</strong> boards like the Apex Pro use magnets to track every millimetre. Rapid Trigger resets the key the instant you lift your finger — letting you stop or strafe faster than physically possible on a normal board.</p>
      <h3>Why Creamy sounds better</h3>
      <p>Traditional clicky keyboards are loud and hollow. Creamy boards like the <strong>Aula F99</strong> use pre-lubed switches and gasket mounts to dampen vibrations, creating a deep, satisfying thock that feels much more premium.</p>
      <p class="last-updated"><em>Last updated: ${BUILD_MONTH}. Prices checked weekly.</em></p>
    `,
  },
  headsets: {
    emoji: '🎧',
    pageTitle: `Best Gaming Headsets UK ${new Date().getFullYear()} | StackPick`,
    metaDescription: 'Best gaming headsets for UK gamers. From audiophile open-back to wireless premium — verified UK pricing on Amazon.',
    heroTitle: 'Best Gaming Headsets (UK)',
    heroSubtitle: `From open-back audiophile to wireless premium. Updated ${BUILD_SHORT}.`,
    breadcrumbLabel: 'Gaming Headsets',
    buyingGuide: `
      <h2>The 2026 Headset Guide</h2>
      <h3>Open-back vs Closed-back</h3>
      <p><strong>Open-back</strong> headphones (like the Sennheiser HD 560S) let sound in and out — creating a wider, more natural soundstage that makes footstep positioning in FPS significantly clearer. <strong>Closed-back</strong> headsets isolate you — better for noisy environments.</p>
      <h3>Wireless latency — solved</h3>
      <p>2.4GHz wireless (used by HyperX, SteelSeries, and Logitech) operates at sub-5ms latency — imperceptible in gaming. The remaining reason to choose wired is budget: wired headsets deliver better hardware per pound at the same price point.</p>
      <p class="last-updated"><em>Last updated: ${BUILD_MONTH}. Prices checked weekly.</em></p>
    `,
  },
  monitors: {
    emoji: '🖥️',
    pageTitle: `Best Gaming Monitors UK ${new Date().getFullYear()} | StackPick`,
    metaDescription: 'Best gaming monitors for UK gamers. OLED, Mini-LED, and budget IPS picks — verified UK pricing on Amazon.',
    heroTitle: 'Best Gaming Monitors (UK)',
    heroSubtitle: `OLED, Mini-LED, and the budget IPS that punches above its weight. Updated ${BUILD_SHORT}.`,
    breadcrumbLabel: 'Gaming Monitors',
    buyingGuide: `
      <h2>2026 Buying Guide: Glossy, Mini-LED &amp; OLED</h2>
      <h3>The Glossy Revolution</h3>
      <p>One of the biggest shifts in 2026 is the move toward Glossy WOLED panels. Traditional matte coatings can make OLED blacks look slightly grey in lit rooms. Glossy panels maintain that infinite contrast and make colours pop.</p>
      <h3>Mini-LED: The OLED Alternative</h3>
      <p>If you work in a bright room or fear OLED burn-in, <strong>Mini-LED</strong> is the standard. Models like the AOC Q27G3XMN offer HDR1000, meaning they get twice as bright as most OLEDs.</p>
      <p class="last-updated"><em>Last updated: ${BUILD_MONTH}. Prices checked weekly.</em></p>
    `,
  },
  chairs: {
    emoji: '🪑',
    pageTitle: `Best Gaming Chairs UK ${new Date().getFullYear()} | StackPick`,
    metaDescription: 'Best gaming chairs for UK gamers. Budget, mesh, back pain relief — verified UK pricing on Amazon.',
    heroTitle: 'Best Gaming Chairs UK',
    heroSubtitle: `Five chairs for five real problems. Crowd-researched picks. Updated ${BUILD_MONTH}.`,
    breadcrumbLabel: 'Gaming Chairs',
    buyingGuide: `
      <h2>The 2026 Chair Buying Guide</h2>
      <h3>Gaming chair vs office chair — honest answer</h3>
      <p>At the budget end (under £200), gaming chairs tend to beat office chairs for comfort and build quality. Once you're spending £300+, ergonomic design matters more than aesthetics.</p>
      <h3>Leather vs mesh — the real difference</h3>
      <p>PU leatherette looks great but gets hot in summer and typically starts cracking after 2–3 years. Mesh breathes significantly better and ages more gracefully. If you run hot, mesh is worth the switch.</p>
      <p class="last-updated"><em>Last updated: ${BUILD_MONTH}. Prices checked weekly.</em></p>
    `,
  },
  controllers: {
    emoji: '🎮',
    pageTitle: `Best Gaming Controllers UK ${new Date().getFullYear()} | StackPick`,
    metaDescription: 'Best gaming controllers for UK gamers. Hall Effect, pro-grade paddles, and budget wireless picks — verified UK pricing.',
    heroTitle: 'Best Gaming Controllers (UK)',
    heroSubtitle: `Hall Effect sticks, pro-grade paddles, and zero-drift picks. Updated ${BUILD_SHORT}.`,
    breadcrumbLabel: 'Gaming Controllers',
    buyingGuide: `
      <h2>The 2026 Controller Guide</h2>
      <h3>Why Hall Effect is Essential</h3>
      <p>Traditional controllers use potentiometers that eventually drift. <strong>Hall Effect sensors</strong> use magnets to track movement, meaning they physically cannot drift. In 2026, we only recommend HE sticks for serious longevity.</p>
      <h3>Mechanical vs Membrane Buttons</h3>
      <p>Pro controllers now use <strong>mechanical switches</strong> for the D-pad and face buttons. They provide a tactile "click" (like a mouse) and actuate 30% faster than traditional rubber membrane buttons.</p>
      <p class="last-updated"><em>Last updated: ${BUILD_MONTH}. Prices checked weekly.</em></p>
    `,
  },
  streaming: {
    emoji: '🎥',
    pageTitle: `Best Streaming Gear UK ${new Date().getFullYear()} | StackPick`,
    metaDescription: 'Best streaming gear for UK creators. 4K webcams, XLR mics, and lighting — verified UK pricing on Amazon.',
    heroTitle: 'Best Streaming Gear (UK)',
    heroSubtitle: `4K webcams, XLR audio, and the gear that makes you look pro. Updated ${BUILD_SHORT}.`,
    breadcrumbLabel: 'Streaming Gear',
    buyingGuide: `
      <h2>The 2026 Creator Guide</h2>
      <h3>Audio is 70% of the Stream</h3>
      <p>Viewers will tolerate 720p video, but they won't tolerate bad audio. We recommend <strong>XLR setups</strong> for the most professional sound, but modern USB-C mics (like the Shure MV7+) have closed the gap significantly.</p>
      <h3>Webcam vs Mirrorless</h3>
      <p>High-end webcams now offer 4K/60fps with large sensors. Unless you are a full-time professional, a premium webcam is easier to manage and delivers 90% of the quality of a complex camera setup.</p>
      <p class="last-updated"><em>Last updated: ${BUILD_MONTH}. Prices checked weekly.</em></p>
    `,
  },
  'desk-accessories': {
    emoji: '💡',
    pageTitle: `Best Desk Accessories UK ${new Date().getFullYear()} | StackPick`,
    metaDescription: 'Best desk accessories for UK gamers. Monitor arms, desk pads, and cable management — verified UK pricing.',
    heroTitle: 'Best Desk Accessories (UK)',
    heroSubtitle: `Monitor arms, premium pads, and the details that finish your setup. Updated ${BUILD_SHORT}.`,
    breadcrumbLabel: 'Desk Accessories',
    buyingGuide: `
      <h2>The 2026 Accessories Guide</h2>
      <h3>Monitor Arms: Reclaim your Desk</h3>
      <p>Standard monitor stands are bulky. A gas-spring <strong>monitor arm</strong> lets you float your screen, giving you back 20% of your desk space for your mousepad and keyboard.</p>
      <h3>Glass vs Cloth Pads</h3>
      <p>Cloth pads are the standard for control. <strong>Glass pads</strong> (like the SkyPAD) offer near-zero friction for effortless tracking. They are more expensive but physically never wear out.</p>
      <p class="last-updated"><em>Last updated: ${BUILD_MONTH}. Prices checked weekly.</em></p>
    `,
  },
};

export async function getStaticPaths() {
  const categories: CategoryKey[] = ['mice', 'keyboards', 'headsets', 'monitors', 'chairs', 'controllers', 'streaming', 'desk-accessories'];
  return categories.map(category => ({ params: { category } }));
}

const { category } = Astro.params as { category: CategoryKey };
const meta = CATEGORY_META[category];

const allProducts = await getCollection('products', p => p.data.category === category);
allProducts.sort((a, b) => (a.data.rank ?? 99) - (b.data.rank ?? 99));
---

<Base
  title={meta.pageTitle}
  description={meta.metaDescription}
  canonical={`https://stackpick.co.uk/${category}/`}
>
  <section slot="hero" class="hero hero--inner">
    <div class="hero-container container">
      <p class="hero-eyebrow">Hardware Category</p>
      <h1>{meta.heroTitle}</h1>
      <p>{meta.heroSubtitle}</p>
    </div>
  </section>

  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="container">
      <ol class="breadcrumb-list">
        <li><a href="/">Home</a></li>
        <li class="breadcrumb-sep" aria-hidden="true">/</li>
        <li><a href="/hardware/">Hardware</a></li>
        <li class="breadcrumb-sep" aria-hidden="true">/</li>
        <li aria-current="page">{meta.breadcrumbLabel}</li>
      </ol>
    </div>
  </nav>

  <!-- Budget filter -->
  <div class="filter-cage filter-cage--sticky">
    <div class="filter-strip" role="group" aria-label="Filter by budget">
      <button class="filter-chip active" data-filter="all">All Budgets</button>
      <button class="filter-chip" data-filter="budget">Budget</button>
      <button class="filter-chip" data-filter="mid-range">Mid-Range</button>
      <button class="filter-chip" data-filter="premium">Premium</button>
      <button class="filter-chip" data-filter="enthusiast">Enthusiast</button>
    </div>
  </div>

  <!-- Product grid -->
  <section class="product-grid" id="product-list" aria-label={`${meta.breadcrumbLabel} picks`}>
    {allProducts.map((product, i) => (
      <ProductCard
        id={product.data.id}
        rank={i + 1}
        name={product.data.name}
        brand={product.data.brand}
        badge={product.data.badge}
        seam={product.data.seam}
        emoji={product.data.emoji}
        price={product.data.price}
        priceRaw={product.data.priceRaw}
        msrp={product.data.msrp}
        savings={product.data.savings}
        affiliate={product.data.affiliate}
        desc={product.body}
        specs={product.data.specs}
        pros={product.data.pros}
        cons={product.data.cons}
        tags={product.data.tags}
        inStock={product.data.inStock}
        nextDay={product.data.nextDay}
        loadoutCount={product.data.loadoutCount}
      />
    ))}
  </section>

  <!-- Buying guide -->
  <section class="section">
    <div class="section-head">
      <h2>What to Look For</h2>
    </div>
    <div class="buying-guide" set:html={meta.buyingGuide} />
  </section>

  <script>
    const chips = document.querySelectorAll('.filter-chip');
    chips.forEach(chip => {
      chip.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLElement;
        const filter = target.dataset.filter;
        document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
        target.classList.add('active');
        document.querySelectorAll<HTMLElement>('.pcard').forEach(card => {
          const visible = filter === 'all' || card.dataset.budget === filter;
          card.classList.toggle('hidden', !visible);
        });
      });
    });
  </script>

</Base>
