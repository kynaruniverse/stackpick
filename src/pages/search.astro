---
// src/pages/search.astro — v6.0
// Global search: products, setups (guides), comparisons — all client-side

import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const allProducts    = await getCollection('products');
const allComparisons = await getCollection('comparisons');
const allGuides      = await getCollection('guides');

const SEAM_COLOR: Record<string, string> = {
  crimson: 'var(--palette-red-500)',
  cobalt:  'var(--palette-navy-600)',
  jade:    'var(--palette-navy-400)',
  slate:   'var(--palette-carbon-600)',
  amber:   'var(--palette-silver-600)',
};

function ratingFromRank(rank: number): number {
  return [4.9, 4.7, 4.5, 4.3, 4.1][Math.min(rank - 1, 4)] ?? 4.0;
}

const searchIndex = [
  ...allProducts.map(p => ({
    type:      'product',
    title:     p.data.name,
    desc:      p.body.slice(0, 120),
    url:       `/${p.data.category}/#${p.data.id}`,
    category:  p.data.category,
    price:     p.data.price,
    tags:      p.data.tags,
    emoji:     p.data.emoji,
    brand:     p.data.brand,
    seamColor: SEAM_COLOR[p.data.seam] ?? 'var(--color-accent)',
    rating:    ratingFromRank(p.data.rank ?? 3),
    pjson:     JSON.stringify({
      id: p.data.id, name: p.data.name, brand: p.data.brand,
      price: p.data.price, msrp: p.data.msrp, savings: p.data.savings,
      emoji: p.data.emoji, seam: p.data.seam, badge: p.data.badge,
      tags: p.data.tags, specs: p.data.specs, pros: p.data.pros,
      cons: p.data.cons, affiliate: p.data.affiliate,
      inStock: p.data.inStock, nextDay: p.data.nextDay,
      rating: ratingFromRank(p.data.rank ?? 3),
    }),
  })),
  ...allComparisons.map(c => ({
    type:      'comparison',
    title:     c.data.title,
    desc:      c.data.heroSubtitle,
    url:       `/comparisons/${c.slug}/`,
    category:  'comparison',
    price:     null,
    tags:      [] as string[],
    emoji:     c.data.emoji ?? '⚖️',
    brand:     '',
    seamColor: 'var(--color-accent)',
    rating:    null,
    pjson:     null,
  })),
  ...allGuides.map(g => ({
    type:      'guide',
    title:     g.data.title,
    desc:      g.data.heroSubtitle,
    url:       `/guides/${g.slug}/`,
    category:  'guide',
    price:     null,
    tags:      [] as string[],
    emoji:     g.data.emoji ?? '📋',
    brand:     '',
    seamColor: 'var(--color-accent)',
    rating:    null,
    pjson:     null,
  })),
];

const searchIndexJSON = JSON.stringify(searchIndex);
---

<Base
  title="Search Gaming Gear | StackPick"
  description="Search StackPick's database of reviewed gaming gear. Find the best mice, keyboards, headsets, monitors and chairs for UK gamers."
  canonical="https://stackpick.co.uk/search/"
>

  <section slot="hero" class="hero hero--inner" aria-label="Search">
    <div class="hero-container container">
      <p class="hero-eyebrow">Search Database</p>
      <h1>Search StackPick</h1>
      <p>Every product, comparison, and guide — searchable instantly.</p>
    </div>
  </section>

  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="container">
      <ol class="breadcrumb-list">
        <li><a href="/">Home</a></li>
        <li class="breadcrumb-sep" aria-hidden="true">/</li>
        <li aria-current="page">Search</li>
      </ol>
    </div>
  </nav>

  <!-- Search bar -->
  <div class="search-bar">
    <input
      type="search"
      id="search-input"
      class="search-input"
      placeholder="Search mice, keyboards, headsets, tags…"
      autocomplete="off"
      autocorrect="off"
      spellcheck="false"
      aria-label="Search gaming gear"
    />
    <button class="search-btn" id="search-btn" type="button">Search</button>
  </div>

  <!-- Type filter -->
  <div class="filter-cage">
    <div class="filter-strip" role="navigation" aria-label="Filter by type">
      <button class="filter-chip active" data-type="all">All</button>
      <button class="filter-chip" data-type="product">Products</button>
      <button class="filter-chip" data-type="guide">Setups</button>
      <button class="filter-chip" data-type="comparison">Comparisons</button>
    </div>
  </div>

  <p class="search-results-count" id="results-count" aria-live="polite"></p>

  <div id="search-results" class="product-grid" style="padding-top: var(--space-2);" aria-label="Search results"></div>

  <!-- Embed search index -->
  <script type="application/json" id="search-index-data" set:html={searchIndexJSON}></script>

  <script>
    const raw   = document.getElementById('search-index-data')!.textContent!;
    const INDEX = JSON.parse(raw) as SearchItem[];

    interface SearchItem {
      type: string; title: string; desc: string; url: string;
      category: string; price: string | null; tags: string[];
      emoji: string; brand: string; seamColor: string;
      rating: number | null; pjson: string | null;
    }

    const input     = document.getElementById('search-input')     as HTMLInputElement;
    const countEl   = document.getElementById('results-count')    as HTMLElement;
    const results   = document.getElementById('search-results')   as HTMLElement;
    const typeChips = document.querySelectorAll<HTMLElement>('.filter-chip[data-type]');

    let activeType = 'all';

    function esc(s: string): string {
      return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function tagClass(t: string): string {
      const map: Record<string,string> = {
        fps:'fps', pro:'pro', budget:'budget', value:'value', entry:'entry',
        wireless:'wireless', lightweight:'lightweight', comfort:'comfort',
        ergonomic:'ergonomic', audiophile:'audiophile', creator:'creator',
        'hall-effect':'hall-effect'
      };
      return `tag tag--${map[t] ?? 'default'}`;
    }

    function starsStr(r: number): string {
      return '★'.repeat(Math.floor(r)) + (r % 1 >= 0.5 ? '½' : '');
    }

    function renderCard(item: SearchItem): string {
      if (item.type === 'product') {
        const tagsHTML = item.tags.slice(0,2).map(t => `<span class="${tagClass(t)}">${esc(t)}</span>`).join('');
        const stars = item.rating ? `
          <div class="stars"><span class="stars__symbol">${starsStr(item.rating)}</span><span class="stars__score">${item.rating.toFixed(1)}</span></div>` : '';
        return `
          <article class="pcard" style="--seam-color: ${esc(item.seamColor)};"
            ${item.pjson ? `data-pjson='${item.pjson.replace(/'/g,"&#39;")}'` : ''}
            tabindex="0">
            <div class="pcard__visual">
              <div class="pcard__emoji">${esc(item.emoji)}</div>
            </div>
            <div class="pcard__body">
              <span class="pcard__brand">${esc(item.brand)}</span>
              <h3 class="pcard__name">${esc(item.title)}</h3>
              ${item.price ? `<div class="pcard__price-row"><span class="price-current">${esc(item.price)}</span></div>` : ''}
              ${stars}
              ${tagsHTML ? `<div class="pcard__tags">${tagsHTML}</div>` : ''}
              <div class="pcard__actions">
                <a href="${esc(item.url)}" class="btn-wishlist">View →</a>
              </div>
            </div>
          </article>`;
      }

      // Guide / Comparison — wider card
      const typeLabel = item.type === 'guide' ? 'Setup Guide' : 'Comparison';
      return `
        <article class="also-card" style="grid-column: 1 / -1;">
          <span class="also-card__icon">${esc(item.emoji)}</span>
          <div>
            <div style="font-family:var(--font-mono);font-size:9px;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-accent);margin-bottom:3px;">${typeLabel}</div>
            <h3 class="also-card__title"><a href="${esc(item.url)}" class="search-result-link">${esc(item.title)}</a></h3>
            <p class="also-card__desc">${esc(item.desc ?? '')}</p>
          </div>
          <a href="${esc(item.url)}" class="also-card__arrow" aria-label="View ${esc(item.title)}">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        </article>`;
    }

    function search(query: string) {
      const q = query.trim().toLowerCase();
      if (!q) {
        results.innerHTML = '';
        countEl.textContent = '';
        return;
      }
      let hits = INDEX.filter(item =>
        item.title.toLowerCase().includes(q)    ||
        item.desc.toLowerCase().includes(q)     ||
        item.category.toLowerCase().includes(q) ||
        item.brand?.toLowerCase().includes(q)   ||
        item.tags.some(t => t.toLowerCase().includes(q))
      );
      if (activeType !== 'all') {
        hits = hits.filter(h => h.type === activeType);
      }
      countEl.textContent = `${hits.length} result${hits.length !== 1 ? 's' : ''} for "${query}"`;
      results.innerHTML = hits.length
        ? hits.map(renderCard).join('')
        : `<p style="color:var(--color-text-muted); padding: var(--space-4) var(--page-pad-mobile); grid-column:1/-1;">No results found.</p>`;
    }

    // Type filter
    typeChips.forEach(chip => {
      chip.addEventListener('click', () => {
        typeChips.forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
        activeType = chip.dataset.type ?? 'all';
        search(input.value);
      });
    });

    input.addEventListener('input',   () => search(input.value));
    input.addEventListener('keydown', e  => { if (e.key === 'Enter') search(input.value); });
    document.getElementById('search-btn')!.addEventListener('click', () => search(input.value));

    // Read ?q= from URL (for topbar redirect)
    const urlQ = new URLSearchParams(window.location.search).get('q');
    if (urlQ) {
      input.value = urlQ;
      search(urlQ);
    } else {
      input.focus();
    }
  </script>

  <style>
    .search-result-link { color: inherit; text-decoration: none; }
    .search-result-link:hover { color: var(--color-accent); text-decoration: underline; }
  </style>

</Base>
