---
// src/pages/comparisons/[slug].astro
// Generates one page per comparison, e.g. /comparisons/razer-viper-v3-pro-vs-logitech-g502x-plus/

import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const comparisons = await getCollection('comparisons');
  return comparisons.map(comp => {
    // Priority 1: The slug defined in frontmatter
    // Priority 2: The filename (comp.slug)
    const actualSlug = comp.data.slug || comp.slug;
    
    return {
      params: { slug: actualSlug },
      props:  { comp },
    };
  });
}



const { comp } = Astro.props;
const { data }  = comp;

// Render the intro + verdict from the markdown body
const { Content } = await comp.render();

type SpecRow    = { label: string; a: string; b: string; winner?: 'a' | 'b' | 'tie' };
type Section    = { heading: string; body: string };
type BuyPoint   = { heading: string; points: string[] };
type BuySection = { heading: string; buyA: BuyPoint; buyB: BuyPoint };
type RelatedLink = { href: string; label: string };

const specTable    = data.specTable    as SpecRow[];
const sections     = data.sections     as Section[];
const buySection   = data.buySection   as BuySection;
const relatedLinks = data.relatedLinks as RelatedLink[];
---

<Base
  title={data.metaTitle}
  description={data.metaDescription}
  canonical={`https://stackpick.co.uk/comparisons/${data.slug || comp.slug}/`}
  ogType="article"
>


  <section slot="hero" class="hero hero--inner">
    <div class="hero-container container">
      <p class="hero-eyebrow">Head-to-Head Comparison</p>
      <h1>{data.heroTitle}</h1>
      <p>{data.heroSubtitle}</p>
    </div>
  </section>

  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="container">
      <ol class="breadcrumb-list">
        <li><a href="/">Home</a></li>
        <li class="breadcrumb-sep" aria-hidden="true">/</li>
        <li><a href="/comparisons/">Comparisons</a></li>
        <li class="breadcrumb-sep" aria-hidden="true">/</li>
        <li aria-current="page">{data.breadcrumbLabel}</li>
      </ol>
    </div>
  </nav>

  <article class="buying-guide">

    <!-- Intro from markdown body -->
    <div class="comparison-intro">
      <Content />
    </div>

    <!-- Product buy boxes — two column -->
    <div class="comparison-products">
      {[data.productA, data.productB].map(product => (
        <div
          class="comparison-product-card"
          style={`--seam-color: ${product.badgeColor}`}
        >
          <!--
            Badge: badgeColor from content schema applied as --seam-color
            custom property. Avoids raw hex in inline style on the element.
          -->
          <span
            class="rank-badge"
            style="background: var(--seam-color); border-color: var(--seam-color); color: #fff;"
          >
            {product.badge}
          </span>
          <h2 class="product-entry__name">{product.name}</h2>
          <p class="product-entry__desc">{product.desc}</p>
          <div class="price-block">
            <span class="price-current">{product.price}</span>
          </div>
          <a
            href={product.affiliate}
            class="btn-primary"
            target="_blank"
            rel="noopener sponsored"
            aria-label={`Buy ${product.name} on Amazon UK — ${product.price}`}
          >
            View on Amazon
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
          </a>
          <a
            href={product.linkHref}
            class="btn-secondary"
            aria-label={product.linkLabel}
          >
            {product.linkLabel}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        </div>
      ))}
    </div>

    <!-- Spec table -->
    <div class="section-head">
      <h2>Specs at a Glance</h2>
    </div>
    <div class="comparison-table-wrapper">
      <table class="comparison-table">
        <thead>
          <tr>
            <th scope="col">Specification</th>
            <th scope="col">{data.productA.name}</th>
            <th scope="col">{data.productB.name}</th>
          </tr>
        </thead>
        <tbody>
          {specTable.map(row => (
            <tr>
              <td>{row.label}</td>
              <td class:list={[row.winner === 'a' && 'winner']}>{row.a}</td>
              <td class:list={[row.winner === 'b' && 'winner']}>{row.b}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Analysis sections -->
    {sections.map(section => (
      <div class="comparison-section">
        <h2>{section.heading}</h2>
        <p>{section.body}</p>
      </div>
    ))}

    <!-- Buy recommendation callout -->
    {buySection && (
      <div class="callout">
        <p class="callout__title">{buySection.heading}</p>
        <div class="comparison-buy-cols">
          {[buySection.buyA, buySection.buyB].map(col => (
            <div class="comparison-buy-col">
              <h3>{col.heading}</h3>
              <ul class="pros-cons__list">
                {col.points.map(point => (
                  <li class="pros-cons__item">{point}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    )}

    <p class="last-updated">Last verified: {data.dateModified}</p>

    <!-- Related links -->
    {relatedLinks.length > 0 && (
      <div class="section">
        <div class="section-head">
          <h2>Related</h2>
        </div>
        <div class="also-grid">
          {relatedLinks.map(link => (
            <a href={link.href} class="also-card">
              <div>
                <h3 class="also-card__title">{link.label}</h3>
              </div>
              <span class="also-card__arrow" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    )}

  </article>
</Base>
