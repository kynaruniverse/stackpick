---
// src/pages/comparisons/index.astro — v6.0
// Compare page: swipe-based product comparison + editorial head-to-head

import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { SEAM_COLOR, ratingFromRank, tagClass } from '../../lib/productUtils';

const allProducts = await getCollection('products');
const allComparisons = await getCollection('comparisons');

// Sort comparisons by date modified (newest first)
allComparisons.sort((a, b) => new Date(b.data.dateModified).getTime() - new Date(a.data.dateModified).getTime());

// Sort products by category then rank
allProducts.sort((a, b) => {
  if (a.data.category !== b.data.category) return a.data.category.localeCompare(b.data.category);
  return (a.data.rank ?? 99) - (b.data.rank ?? 99);
});

const BUILD_MONTH = new Date().toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
---

<Base
  title="Gaming Gear Comparisons UK | StackPick"
  description="Head-to-head comparisons of the top gaming gear. Which mouse, keyboard, headset or monitor wins for UK gamers?"
  canonical="https://stackpick.co.uk/comparisons/"
>

  <section slot="hero" class="hero hero--inner" aria-label="Compare gear">
    <div class="hero-container container">
      <p class="hero-eyebrow">Comparisons</p>
      <h1>Compare Gear</h1>
      <p>Swipe through side-by-side breakdowns or read our expert head-to-head verdicts.</p>
    </div>
  </section>

  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="container">
      <ol class="breadcrumb-list">
        <li><a href="/">Home</a></li>
        <li class="breadcrumb-sep" aria-hidden="true">/</li>
        <li aria-current="page">Compare</li>
      </ol>
    </div>
  </nav>

  <!-- ═══ SWIPE COMPARE (all products) ═══ -->
  <section aria-label="Swipe through all products" class="section--swipe">
    <div class="section-head container">
      <span class="section-head__label">All Products</span>
      <h2 class="section-head__title">Swipe to Compare</h2>
      <span id="compare-count" class="compare-nav__count" style="margin-left:auto; font-family:var(--font-mono); font-size:var(--text-xs); color:var(--color-text-muted);">1 / {allProducts.length}</span>
    </div>

    <div class="compare-swipe" id="compare-swipe" aria-label="Product cards">
      {allProducts.map((product) => {
        const rating = ratingFromRank(product.data.rank ?? 3);
        const seamColor = SEAM_COLOR[product.data.seam] ?? 'var(--color-accent)';
        const starsStr = '★'.repeat(Math.floor(rating)) + (rating % 1 >= 0.5 ? '½' : '');
        return (
          <div class="compare-card" style={`--seam-color: ${seamColor};`} data-id={product.data.id}>
            <a href={`/products/${product.data.id}/`} class="compare-card__link" aria-label={`View details for ${product.data.name}`}>
              <div class="compare-card__visual">
                <div class="compare-card__visual-emoji" aria-hidden="true">{product.data.emoji}</div>
              </div>
            </a>

            <div class="compare-card__body">
              <div class="compare-card__brand">{product.data.brand}</div>
              <h3 class="compare-card__name">{product.data.name}</h3>

              <div class="compare-card__price">
                <span class="price-current">{product.data.price}</span>
                <span class="last-verified">Verified {BUILD_MONTH}</span>
              </div>

              <div class="stars" aria-label={`Rating: ${rating}`}>
                <span class="stars__symbol" aria-hidden="true">{starsStr}</span>
                <span class="stars__score">{rating.toFixed(1)}</span>
              </div>

              <div class="compare-card__tags">
                {product.data.tags.slice(0,3).map((t: string) => (
                  <span class={tagClass(t)}>{t}</span>
                ))}
              </div>

              <div class="compare-card__specs">
                {product.data.specs.map((s: string) => (
                  <span class="spec-pill">{s}</span>
                ))}
              </div>

              <div class="compare-card__prose">
                <div class="compare-card__prose-col">
                  <div class="compare-card__col-label compare-card__col-label--pros">Pros</div>
                  <ul class="compare-card__list">
                    {product.data.pros.slice(0,3).map((p: string) => <li>{p}</li>)}
                  </ul>
                </div>
                <div class="compare-card__prose-col">
                  <div class="compare-card__col-label compare-card__col-label--cons">Cons</div>
                  <ul class="compare-card__list">
                    {product.data.cons.slice(0,2).map((c: string) => <li>{c}</li>)}
                  </ul>
                </div>
              </div>

              <div class="compare-card__actions">
                <a href={product.data.affiliate} class="btn-primary" target="_blank" rel="noopener sponsored"
                  data-product={product.data.id} data-type="compare-cta">
                  Amazon UK ↗
                </a>
                <button class="btn-wishlist" data-id={product.data.id} aria-pressed="false">
                  ♡ Save
                </button>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Swipe nav dots -->
    <div class="compare-nav" aria-hidden="true">
      {allProducts.slice(0, 8).map((_, i) => (
        <button class:list={['compare-nav__dot', i === 0 && 'active']} data-index={i} aria-label={`Go to product ${i + 1}`}></button>
      ))}
      {allProducts.length > 8 && <span class="compare-nav__count">+{allProducts.length - 8} more</span>}
    </div>
  </section>

  <!-- ═══ EDITORIAL COMPARISONS ═══ -->
  <section aria-label="Head-to-head comparisons" class="section--editorial">
    <div class="section-head container">
      <span class="section-head__label">Expert Reviews</span>
      <h2 class="section-head__title">Head-to-Head</h2>
    </div>
    <div class="container">
      <div class="also-grid">
        {allComparisons.map(comp => (
          <a href={`/comparisons/${comp.slug}/`} class="also-card">
            <span class="also-card__icon" aria-hidden="true">{comp.data.emoji}</span>
            <div class="also-card__content">
              <h3 class="also-card__title">{comp.data.title}</h3>
              <p class="also-card__desc">{comp.data.heroSubtitle}</p>
            </div>
            <span class="also-card__arrow" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <style>
    .section--swipe { padding-bottom: var(--space-12); }
    .section--editorial { padding: var(--space-12) 0 var(--space-16); background: var(--color-bg-inset); border-top: 1px solid var(--color-border); }
    
    .compare-card__link { display: block; text-decoration: none; }
    .compare-card__price { display: flex; align-items: baseline; gap: var(--space-2); margin-top: var(--space-2); }
    .last-verified { font-size: 10px; color: var(--color-text-dim); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
    
    .compare-card__prose { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); margin-top: var(--space-6); }
    .compare-card__col-label { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: var(--space-2); }
    .compare-card__col-label--pros { color: var(--color-success, #10b981); }
    .compare-card__col-label--cons { color: var(--color-error, #ef4444); }
    
    .compare-card__actions { display: grid; grid-template-columns: 1fr auto; gap: var(--space-2); margin-top: var(--space-8); }
    
    @media (max-width: 768px) {
      .compare-swipe { padding: 0 var(--page-pad-mobile); }
      .compare-card { width: calc(100vw - 48px); }
    }
  </style>

  <script>
    // ── Scroll counter + nav dots ────────────────────
    const swipe = document.getElementById('compare-swipe');
    const dots  = document.querySelectorAll<HTMLElement>('.compare-nav__dot');
    const count = document.getElementById('compare-count');
    const total = swipe?.children.length ?? 0;

    function updateNav() {
      if (!swipe) return;
      const cardW = (swipe.firstElementChild as HTMLElement)?.offsetWidth ?? 1;
      const gap   = 16;
      const idx   = Math.round(swipe.scrollLeft / (cardW + gap));
      dots.forEach((d, i) => d.classList.toggle('active', i === idx));
      if (count) count.textContent = `${idx + 1} / ${total}`;
    }

    swipe?.addEventListener('scroll', updateNav, { passive: true });

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        const cardW = (swipe?.firstElementChild as HTMLElement)?.offsetWidth ?? 1;
        swipe?.scrollTo({ left: i * (cardW + 16), behavior: 'smooth' });
      });
    });
  </script>

</Base>
