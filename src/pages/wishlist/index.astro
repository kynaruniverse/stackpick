---
// src/pages/wishlist/index.astro — v6.0
// Wishlist: localStorage-backed, 2-col grid, remove + expand overlay

import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

// Pass ALL product data to client as JSON for rendering
const allProducts = await getCollection('products');
const SEAM_COLOR: Record<string, string> = {
  crimson: 'var(--palette-red-500)',
  cobalt:  'var(--palette-navy-600)',
  jade:    'var(--palette-navy-400)',
  slate:   'var(--palette-carbon-600)',
  amber:   'var(--palette-silver-600)',
};

function ratingFromRank(rank: number): number {
  return [4.9, 4.7, 4.5, 4.3, 4.1][Math.min(rank - 1, 4)] ?? 4.0;
}

const allProductsData = allProducts.map(p => ({
  id:        p.data.id,
  name:      p.data.name,
  brand:     p.data.brand,
  price:     p.data.price,
  msrp:      p.data.msrp,
  savings:   p.data.savings,
  emoji:     p.data.emoji,
  seam:      p.data.seam,
  badge:     p.data.badge,
  tags:      p.data.tags,
  specs:     p.data.specs,
  pros:      p.data.pros,
  cons:      p.data.cons,
  affiliate: p.data.affiliate,
  inStock:   p.data.inStock,
  nextDay:   p.data.nextDay,
  rating:    ratingFromRank(p.data.rank ?? 3),
  seamColor: SEAM_COLOR[p.data.seam] ?? 'var(--color-accent)',
}));

const allProductsJSON = JSON.stringify(allProductsData);
---

<Base
  title="My Wishlist | StackPick"
  description="Your saved gaming gear picks. Build your perfect UK gaming setup."
  canonical="https://stackpick.co.uk/wishlist/"
>

  <section slot="hero" class="hero hero--inner" aria-label="Wishlist">
    <div class="hero-container container">
      <p class="hero-eyebrow">Your Collection</p>
      <h1>Wishlist</h1>
      <p>Saved gear — tap any card for details, swipe to compare.</p>
    </div>
  </section>

  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="container">
      <ol class="breadcrumb-list">
        <li><a href="/">Home</a></li>
        <li class="breadcrumb-sep" aria-hidden="true">/</li>
        <li aria-current="page">Wishlist</li>
      </ol>
    </div>
  </nav>

  <!-- Wishlist count -->
  <div class="wishlist-count" id="wishlist-count" aria-live="polite"></div>

  <!-- Empty state -->
  <div class="wishlist-empty hidden" id="wishlist-empty">
    <span class="wishlist-empty__icon" aria-hidden="true">♡</span>
    <h2 class="wishlist-empty__title">Nothing saved yet</h2>
    <p class="wishlist-empty__desc">Browse gear and tap "Save" to add products here.</p>
    <a href="/hardware/" class="btn-primary" style="margin-top: var(--space-2);">
      Browse Hardware
    </a>
  </div>

  <!-- Wishlist grid -->
  <div class="wishlist-grid" id="wishlist-grid" aria-label="Saved products">
    <!-- Populated by JS -->
  </div>

  <!-- Embed all product data -->
  <script type="application/json" id="all-products-data" set:html={allProductsJSON}></script>

  <script>
    const raw        = document.getElementById('all-products-data')!.textContent!;
    const ALL_PRODS  = JSON.parse(raw) as ProductWL[];
    const PROD_MAP   = new Map(ALL_PRODS.map(p => [p.id, p]));

    const grid       = document.getElementById('wishlist-grid')!;
    const empty      = document.getElementById('wishlist-empty')!;
    const countEl    = document.getElementById('wishlist-count')!;

    interface ProductWL {
      id: string; name: string; brand: string; price: string;
      msrp: string|null; savings: string|null; emoji: string;
      seam: string; badge: string; tags: string[]; specs: string[];
      pros: string[]; cons: string[]; affiliate: string;
      inStock: boolean; nextDay: boolean; rating: number; seamColor: string;
    }

    const WL_KEY = 'sp-wishlist-v1';
    function getWL(): string[] {
      try { return JSON.parse(localStorage.getItem(WL_KEY) ?? '[]'); } catch { return []; }
    }
    function saveWL(ids: string[]) {
      try { localStorage.setItem(WL_KEY, JSON.stringify(ids)); } catch {}
    }
    function removeFromWL(id: string) {
      const wl = getWL().filter(x => x !== id);
      saveWL(wl);
      renderGrid();
      window.dispatchEvent(new CustomEvent('wishlist-changed', { detail: { wl } }));
    }

    function tagClass(t: string): string {
      const map: Record<string,string> = {
        fps:'fps', pro:'pro', budget:'budget', value:'value', entry:'entry',
        wireless:'wireless', lightweight:'lightweight', comfort:'comfort',
        ergonomic:'ergonomic', audiophile:'audiophile', creator:'creator',
        'hall-effect':'hall-effect'
      };
      return `tag tag--${map[t] ?? 'default'}`;
    }

    function starsStr(r: number): string {
      return '★'.repeat(Math.floor(r)) + (r % 1 >= 0.5 ? '½' : '');
    }

    function buildCard(p: ProductWL): string {
      const tagsHTML = p.tags.slice(0,2).map(t => `<span class="${tagClass(t)}">${t}</span>`).join('');
      const extra = p.tags.length > 2 ? `<span class="tag" style="background:var(--color-bg-subtle);color:var(--color-text-muted);">+${p.tags.length-2}</span>` : '';
      return `
        <article class="pcard" data-id="${p.id}" style="--seam-color: ${p.seamColor};"
          data-pjson='${JSON.stringify(p).replace(/'/g,"&#39;")}' tabindex="0">
          <div class="pcard__visual">
            <span class="pcard__rank-badge" style="background:${p.seamColor};">${p.badge.slice(0,12)}</span>
            <div class="pcard__emoji">${p.emoji}</div>
          </div>
          <div class="pcard__body">
            <span class="pcard__brand">${p.brand}</span>
            <h3 class="pcard__name">${p.name}</h3>
            <div class="pcard__price-row">
              <span class="price-current">${p.price}</span>
              ${p.savings ? `<span class="price-badge">-${p.savings}</span>` : ''}
            </div>
            <div class="stars">
              <span class="stars__symbol">${starsStr(p.rating)}</span>
              <span class="stars__score">${p.rating.toFixed(1)}</span>
            </div>
            <div class="pcard__tags">${tagsHTML}${extra}</div>
            <div class="pcard__actions">
              <button class="btn-remove" data-remove="${p.id}" aria-label="Remove ${p.name} from wishlist">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                Remove
              </button>
              <a href="${p.affiliate}" class="btn-compare" target="_blank" rel="noopener sponsored" onclick="event.stopPropagation()">Amazon ↗</a>
            </div>
          </div>
        </article>`;
    }

    function renderGrid() {
      const wl = getWL();
      const products = wl.map(id => PROD_MAP.get(id)).filter(Boolean) as ProductWL[];

      if (products.length === 0) {
        grid.innerHTML = '';
        empty.classList.remove('hidden');
        countEl.textContent = '';
      } else {
        empty.classList.add('hidden');
        grid.innerHTML = products.map(buildCard).join('');
        countEl.textContent = `${products.length} item${products.length !== 1 ? 's' : ''} saved`;

        // Wire remove buttons
        grid.querySelectorAll<HTMLButtonElement>('[data-remove]').forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const id = btn.dataset.remove!;
            removeFromWL(id);
          });
        });
      }
    }

    // Initial render
    renderGrid();

    // React to wishlist changes from other tabs/components
    window.addEventListener('wishlist-changed', () => renderGrid());
    window.addEventListener('storage', (e) => {
      if (e.key === WL_KEY) renderGrid();
    });
  </script>

</Base>
