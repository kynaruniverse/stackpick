---
// src/pages/wishlist/index.astro — v6.0
// Wishlist: localStorage-backed, 2-col grid, remove + expand overlay + shareable setups

import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { SEAM_COLOR, ratingFromRank } from '../../lib/productUtils';

// Pass ALL product data to client as JSON for rendering
const allProducts = await getCollection('products');

const allProductsData = allProducts.map(p => ({
  id:        p.data.id,
  name:      p.data.name,
  brand:     p.data.brand,
  price:     p.data.price,
  msrp:      p.data.msrp,
  savings:   p.data.savings,
  emoji:     p.data.emoji,
  seam:      p.data.seam,
  badge:     p.data.badge,
  tags:      p.data.tags,
  specs:     p.data.specs,
  pros:      p.data.pros,
  cons:      p.data.cons,
  affiliate: p.data.affiliate,
  inStock:   p.data.inStock,
  nextDay:   p.data.nextDay,
  rating:    ratingFromRank(p.data.rank ?? 3),
  seamColor: SEAM_COLOR[p.data.seam] ?? 'var(--color-accent)',
}));

const allProductsJSON = JSON.stringify(allProductsData);

const BUILD_MONTH = new Date().toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
---

<Base
  title="My Gaming Wishlist | StackPick UK"
  description="Your saved gaming gear picks. Build, compare, and share your perfect UK gaming setup."
  canonical="https://stackpick.co.uk/wishlist/"
>

  <section slot="hero" class="hero hero--inner" aria-label="Wishlist">
    <div class="hero-container container">
      <p class="hero-eyebrow">Your Collection</p>
      <h1>Wishlist</h1>
      <p>Your curated gear for {BUILD_MONTH}. Tap any card for details or share your setup.</p>
    </div>
  </section>

  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="container">
      <ol class="breadcrumb-list">
        <li><a href="/">Home</a></li>
        <li class="breadcrumb-sep" aria-hidden="true">/</li>
        <li aria-current="page">Wishlist</li>
      </ol>
    </div>
  </nav>

  <div class="wishlist-controls container">
    <div class="wishlist-meta">
      <div class="wishlist-count" id="wishlist-count" aria-live="polite"></div>
      <p class="last-verified">Prices verified {BUILD_MONTH}</p>
    </div>
    <div class="wishlist-actions">
      <button id="share-wishlist" class="btn-primary btn-share">
        Share My Setup
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
      </button>
    </div>
  </div>

  <!-- Empty state -->
  <div class="wishlist-empty hidden" id="wishlist-empty">
    <div class="wishlist-empty__visual" aria-hidden="true">♡</div>
    <h2 class="wishlist-empty__title">Your collection is empty</h2>
    <p class="wishlist-empty__desc">Browse the hardware database and save the gear that fits your playstyle.</p>
    <a href="/hardware/" class="btn-primary">Browse Hardware</a>
  </div>

  <!-- Wishlist grid -->
  <section class="wishlist-grid-wrapper container">
    <div class="wishlist-grid" id="wishlist-grid" aria-live="polite">
      <!-- Populated by JS -->
    </div>
  </section>

  <!-- Embed all product data -->
  <script type="application/json" id="all-products-data" set:html={allProductsJSON}></script>

  <style>
    .wishlist-controls { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: var(--space-8); margin-top: var(--space-8); }
    .wishlist-meta { display: flex; flex-direction: column; gap: 4px; }
    .wishlist-count { font-family: var(--font-mono); font-weight: 800; font-size: var(--text-sm); color: var(--color-text-primary); text-transform: uppercase; }
    .last-verified { font-size: 10px; color: var(--color-text-dim); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 700; }
    
    .btn-share { padding: 12px 24px; font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; display: flex; align-items: center; gap: 8px; border-radius: 12px; }
    
    .wishlist-empty { text-align: center; padding: var(--space-20) var(--space-4); }
    .wishlist-empty__visual { font-size: 80px; color: var(--color-border); margin-bottom: var(--space-4); }
    .wishlist-empty__title { font-size: var(--text-3xl); font-weight: 900; margin-bottom: var(--space-2); color: var(--color-text-primary); }
    .wishlist-empty__desc { color: var(--color-text-muted); margin-bottom: var(--space-8); max-width: 400px; margin-left: auto; margin-right: auto; }

    .wishlist-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); }
    
    @media (max-width: 768px) {
      .wishlist-grid { grid-template-columns: 1fr; }
      .wishlist-controls { flex-direction: column; align-items: flex-start; gap: var(--space-6); }
      .wishlist-actions { width: 100%; }
      .btn-share { width: 100%; justify-content: center; }
    }
  </style>

  <script>
    const raw        = document.getElementById('all-products-data')!.textContent!;
    const ALL_PRODS  = JSON.parse(raw) as ProductWL[];
    const PROD_MAP   = new Map(ALL_PRODS.map(p => [p.id, p]));

    const grid       = document.getElementById('wishlist-grid')!;
    const empty      = document.getElementById('wishlist-empty')!;
    const countEl    = document.getElementById('wishlist-count')!;

    interface ProductWL {
      id: string; name: string; brand: string; price: string;
      msrp: string|null; savings: string|null; emoji: string;
      seam: string; badge: string; tags: string[]; specs: string[];
      pros: string[]; cons: string[]; affiliate: string;
      inStock: boolean; nextDay: boolean; rating: number; seamColor: string;
    }

    const WL_KEY = 'sp-wishlist-v1';
    function getWL(): string[] {
      try { return JSON.parse(localStorage.getItem(WL_KEY) ?? '[]'); } catch { return []; }
    }
    function saveWL(ids: string[]) {
      try { localStorage.setItem(WL_KEY, JSON.stringify(ids)); } catch {}
    }
    function removeFromWL(id: string) {
      const wl = getWL().filter(x => x !== id);
      saveWL(wl);
      renderGrid();
      window.dispatchEvent(new CustomEvent('wishlist-changed', { detail: { wl } }));
    }

    function tagClass(t: string): string {
      const map: Record<string,string> = {
        fps:'fps', pro:'pro', budget:'budget', value:'value', entry:'entry',
        wireless:'wireless', lightweight:'lightweight', comfort:'comfort',
        ergonomic:'ergonomic', audiophile:'audiophile', creator:'creator',
        'hall-effect':'hall-effect'
      };
      return `tag tag--${map[t] ?? 'default'}`;
    }
    
    function starsStr(r: number): string {
      return '★'.repeat(Math.floor(r)) + (r % 1 >= 0.5 ? '½' : '');
    }

    function buildCard(p: ProductWL): string {
      const tagsHTML = p.tags.slice(0,2).map(t => `<span class="${tagClass(t)}">${t}</span>`).join('');
      const extra = p.tags.length > 2 ? `<span class="tag" style="background:var(--color-bg-subtle);color:var(--color-text-muted);">+${p.tags.length-2}</span>` : '';
      return `
        <article class="pcard" data-id="${p.id}" style="--seam-color: ${p.seamColor};"
          data-pjson='${JSON.stringify(p).replace(/'/g,"&#39;")}' tabindex="0">
          <div class="pcard__visual">
            <span class="pcard__rank-badge" style="background:${p.seamColor};">${p.badge}</span>
            <div class="pcard__emoji">${p.emoji}</div>
          </div>
          <div class="pcard__body">
            <span class="pcard__brand">${p.brand}</span>
            <h3 class="pcard__name">${p.name}</h3>
            <div class="pcard__price-row">
              <span class="price-current">${p.price}</span>
              ${p.savings ? `<span class="price-badge">-${p.savings}</span>` : ''}
            </div>
            <div class="stars">
              <span class="stars__symbol">${starsStr(p.rating)}</span>
              <span class="stars__score">${p.rating.toFixed(1)}</span>
            </div>
            <div class="pcard__tags">${tagsHTML}${extra}</div>
            <div class="pcard__actions">
              <button class="btn-remove" data-remove="${p.id}" aria-label="Remove ${p.name} from wishlist">
                ✕ Remove
              </button>
              <a href="${p.affiliate}" class="btn-compare" target="_blank" rel="noopener sponsored" onclick="event.stopPropagation()">Amazon ↗</a>
            </div>
          </div>
        </article>`;
    }

    // Share Wishlist Logic
    document.getElementById('share-wishlist')?.addEventListener('click', () => {
      const wl = getWL();
      if (wl.length === 0) {
        alert("Your wishlist is empty! Add some gear first.");
        return;
      }
      const ids = wl.join(',');
      const shareUrl = `${window.location.origin}/wishlist/?ids=${ids}`;
      
      navigator.clipboard.writeText(shareUrl).then(() => {
        const btn = document.getElementById('share-wishlist')!;
        const originalText = btn.innerHTML;
        btn.innerHTML = 'Link Copied! ✓';
        setTimeout(() => { btn.innerHTML = originalText; }, 2000);
      }).catch(() => {
        alert("Failed to copy link. Please copy the URL from your browser address bar.");
      });
    });

    function renderGrid() {
      const wl = getWL();
      const products = wl.map(id => PROD_MAP.get(id)).filter(Boolean) as ProductWL[];

      if (products.length === 0) {
        grid.innerHTML = '';
        empty.classList.remove('hidden');
        countEl.textContent = '0 ITEMS SAVED';
      } else {
        empty.classList.add('hidden');
        grid.innerHTML = products.map(buildCard).join('');
        countEl.textContent = `${products.length} ITEM${products.length !== 1 ? 'S' : ''} SAVED`;

        // Wire remove buttons
        grid.querySelectorAll<HTMLButtonElement>('[data-remove]').forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const id = btn.dataset.remove!;
            removeFromWL(id);
          });
        });
      }
    }

    // Initial render
    renderGrid();

    // React to wishlist changes from other tabs/components
    window.addEventListener('wishlist-changed', () => renderGrid());
    window.addEventListener('storage', (e) => {
      if (e.key === WL_KEY) renderGrid();
    });
  </script>

</Base>
