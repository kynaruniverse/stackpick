---
// src/pages/index.astro
// Homepage — product wall with collection tabs.
// All data is server-rendered at build time. No wall.js needed.

import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProductCard from '../components/ProductCard.astro';

// Fetch all data at build time
const allProducts    = await getCollection('products');
const allCollections = await getCollection('collections');

// Build a product lookup map for O(1) access
const productMap = new Map(allProducts.map(p => [p.data.id, p]));

// Sort collections so "all-picks" is always first
const COLLECTION_ORDER = [
  'all-picks', 'sweaty-fps', 'kynar-setup',
  'wireless-only', 'study-mode', 'under-100',
  'cozy-station', 'creator-bay',
];
allCollections.sort((a, b) =>
  COLLECTION_ORDER.indexOf(a.data.id) - COLLECTION_ORDER.indexOf(b.data.id)
);

// Pre-build product lists per collection for server rendering
const collectionProducts = allCollections.map(col => ({
  id:       col.data.id,
  label:    col.data.label,
  emoji:    col.data.emoji,
  color:    col.data.color,
  products: col.data.baseProducts
    .map(id => productMap.get(id))
    .filter(Boolean),
}));
---

<Base
  title="StackPick — Best Gaming Gear for UK Gamers"
  description="Researched gaming gear picks for UK gamers. Best mice, keyboards, headsets, monitors and chairs — tested, ranked, no filler."
  canonical="https://stackpick.co.uk/"
>

  <!-- Homepage hero -->
  <section slot="hero" class="hero hero--home">
    <div class="hero-container container">
      <p class="hero-eyebrow">UK Gaming Gear</p>
      <h1>The Best Gaming Gear<br>for UK Gamers</h1>
      <p>Researched picks across every category. System verified. No filler.</p>
      <div class="hero-actions">
        <a href="/mice/" class="btn-primary">
          Browse Mice
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
        </a>
        <a href="/guides/" class="btn-secondary">Setup Guides</a>
      </div>
    </div>
  </section>

  <!-- Collection tabs -->
  <div class="collection-tabs-bar" id="collection-tabs" role="tablist" aria-label="Browse by collection">
    {collectionProducts.map((col, i) => (
      <button
        role="tab"
        class:list={['collection-tab', i === 0 && 'active']}
        data-collection={col.id}
        aria-selected={i === 0 ? 'true' : 'false'}
        aria-controls={`panel-${col.id}`}
        id={`tab-${col.id}`}
      >
        <span class="collection-tab__emoji">{col.emoji}</span>
        <span class="collection-tab__label">{col.label}</span>
      </button>
    ))}
  </div>

  <!-- Product panels — one per collection, only first is visible -->
  {collectionProducts.map((col, i) => (
    <section
      role="tabpanel"
      id={`panel-${col.id}`}
      class:list={['collection-panel', i !== 0 && 'hidden']}
      aria-labelledby={`tab-${col.id}`}
      aria-hidden={i !== 0 ? 'true' : 'false'}
    >
      <div class="product-list">
        {col.products.map((product, rank) => product && (
          <ProductCard
            id={product.data.id}
            rank={rank + 1}
            name={product.data.name}
            brand={product.data.brand}
            badge={product.data.badge}
            seam={product.data.seam}
            emoji={product.data.emoji}
            price={product.data.price}
            msrp={product.data.msrp}
            savings={product.data.savings}
            affiliate={product.data.affiliate}
            desc={product.body}
            specs={product.data.specs}
            pros={product.data.pros}
            cons={product.data.cons}
            inStock={product.data.inStock}
            nextDay={product.data.nextDay}
            loadoutCount={product.data.loadoutCount}
          />
        ))}
      </div>
    </section>
  ))}

  <!-- Browse categories strip -->
  <section class="section">
    <div class="section-head">
      <h2>Browse by Category</h2>
    </div>
    <div class="also-grid">
      <a href="/mice/" class="also-card">
        <span class="also-card__icon" aria-hidden="true">🖱️</span>
        <div>
          <h3 class="also-card__title">Gaming Mice</h3>
          <p class="also-card__desc">From 40g ultralight to all-round legends</p>
        </div>
        <span class="also-card__arrow" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </span>
      </a>
      <a href="/keyboards/" class="also-card">
        <span class="also-card__icon" aria-hidden="true">⌨️</span>
        <div>
          <h3 class="also-card__title">Keyboards</h3>
          <p class="also-card__desc">Hall Effect, wireless, budget mechanical</p>
        </div>
        <span class="also-card__arrow" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </span>
      </a>
      <a href="/headsets/" class="also-card">
        <span class="also-card__icon" aria-hidden="true">🎧</span>
        <div>
          <h3 class="also-card__title">Headsets</h3>
          <p class="also-card__desc">Open-back audiophile to wireless premium</p>
        </div>
        <span class="also-card__arrow" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </span>
      </a>
      <a href="/monitors/" class="also-card">
        <span class="also-card__icon" aria-hidden="true">🖥️</span>
        <div>
          <h3 class="also-card__title">Monitors</h3>
          <p class="also-card__desc">OLED, Mini-LED, and budget IPS</p>
        </div>
        <span class="also-card__arrow" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </span>
      </a>
      <a href="/chairs/" class="also-card">
        <span class="also-card__icon" aria-hidden="true">🪑</span>
        <div>
          <h3 class="also-card__title">Chairs</h3>
          <p class="also-card__desc">Five chairs for five real problems</p>
        </div>
        <span class="also-card__arrow" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </span>
      </a>
      <a href="/guides/" class="also-card">
        <span class="also-card__icon" aria-hidden="true">📋</span>
        <div>
          <h3 class="also-card__title">Setup Guides</h3>
          <p class="also-card__desc">Complete builds from £50 to £2500</p>
        </div>
        <span class="also-card__arrow" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </span>
      </a>
    </div>
  </section>

  <!-- Tab switching script — zero dependencies -->
  <script>
    const tabs   = document.querySelectorAll<HTMLElement>('.collection-tab');
    const panels = document.querySelectorAll<HTMLElement>('.collection-panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const id = tab.dataset.collection!;

        tabs.forEach(t => {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');

        panels.forEach(panel => {
          const isTarget = panel.id === `panel-${id}`;
          panel.classList.toggle('hidden', !isTarget);
        // display:none already removes from a11y tree; aria-hidden is redundant
        // but keep for belt-and-suspenders with older AT
        panel.setAttribute('aria-hidden', isTarget ? 'false' : 'true');
        if (!isTarget) {
          panel.setAttribute('inert', '');
        } else {
        panel.removeAttribute('inert');
        }        });
      });
    });
  </script>

</Base>
