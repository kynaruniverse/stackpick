---
// src/pages/index.astro — v6.0 Mobile-First Homepage
// Fully updated for Phase 2 & 3: New categories, quick-picks, and verified data.

import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProductCard from '../components/ProductCard.astro';

const allProducts    = await getCollection('products');
const allCollections = await getCollection('collections');
const allGuides      = await getCollection('guides');

const productMap = new Map(allProducts.map(p => [p.data.id, p]));

const COLLECTION_ORDER = [
  'all-picks', 'sweaty-fps', 'kynar-setup',
  'wireless-only', 'study-mode', 'under-100',
  'cozy-station', 'creator-bay',
];

allCollections.sort((a, b) =>
  COLLECTION_ORDER.indexOf(a.data.id) - COLLECTION_ORDER.indexOf(b.data.id)
);

const collectionProducts = allCollections.map(col => ({
  id:       col.data.id,
  label:    col.data.label,
  emoji:    col.data.emoji,
  products: (col.data.baseProducts as string[])
    .map(id => productMap.get(id))
    .filter(Boolean),
}));

// Featured = rank-1 products from each category for carousel
const featuredProducts = ['mice', 'keyboards', 'headsets', 'monitors', 'chairs', 'controllers', 'streaming']
  .map(cat => allProducts.find(p => p.data.category === cat && p.data.rank === 1))
  .filter(Boolean);

const featuredGuides = allGuides.slice(0, 3);

const categories = [
  { slug: 'mice',      icon: '🖱️', name: 'Mice',      count: '5 picks' },
  { slug: 'keyboards', icon: '⌨️', name: 'Keyboards', count: '5 picks' },
  { slug: 'headsets',  icon: '🎧', name: 'Headsets',  count: '5 picks' },
  { slug: 'monitors',  icon: '🖥️', name: 'Monitors',  count: '5 picks' },
  { slug: 'chairs',    icon: '🪑', name: 'Chairs',    count: '5 picks' },
  { slug: 'controllers', icon: '🎮', name: 'Controllers', count: '5 picks' },
  { slug: 'streaming',  icon: '🎥', name: 'Streaming',  count: '5 picks' },
  { slug: 'desk-accessories', icon: '💡', name: 'Desk Gear', count: '5 picks' },
];

const specComparison = [
  { label: 'Lowest verified price', a: '£28',     b: '£399+'  },
  { label: 'Mouse polling rate',    a: '125Hz',   b: '8,000Hz'},
  { label: 'Monitor refresh rate',  a: '75Hz',    b: '500Hz'  },
  { label: 'Keyboard polling',      a: '1,000Hz', b: '8,000Hz'},
];

const BUILD_MONTH = new Date().toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
---

<Base
  title="StackPick — Best Gaming Gear for UK Gamers"
  description="Researched gaming gear picks for UK gamers. Best mice, keyboards, headsets, monitors and chairs — verified UK pricing, no filler."
  canonical="https://stackpick.co.uk/"
>

  <!-- ═══ HERO ═══ -->
  <section slot="hero" class="hero hero--home" aria-label="Site hero">
    <div class="hero-container container">
      <p class="hero-eyebrow">Independently Researched · UK Prices Verified {BUILD_MONTH}</p>
      <h1>Ranked Gaming Gear<br>for UK Gamers.</h1>
      <p>The definitive guide to the UK gaming market. {allProducts.length} verified picks across {categories.length} categories. Real prices. No filler.</p>
      <div class="hero-actions">
        <a href="/hardware/" class="btn-primary">
          Browse All Picks
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
        </a>
        <a href="/guides/" class="btn-secondary">Setup Guides</a>
      </div>
    </div>
  </section>

  <!-- ═══ FEATURED CAROUSEL ═══ -->
  <section aria-label="Featured top picks" style="border-bottom: 1px solid var(--color-border);">
    <div class="section-head">
      <span class="section-head__label">Top Picks</span>
      <span class="section-head__title">Featured Gear</span>
      <a href="/hardware/" class="section-head__link">All →</a>
    </div>
    <div class="carousel" id="featured-carousel">
      <div class="carousel__track" id="carousel-track">
        {featuredProducts.map((product) => product && (
          <div class="carousel__slide">
            <ProductCard
              id={product.data.id}
              rank={product.data.rank ?? 1}
              name={product.data.name}
              brand={product.data.brand}
              badge={product.data.badge}
              seam={product.data.seam}
              emoji={product.data.emoji}
              price={product.data.price}
              priceRaw={product.data.priceRaw}
              msrp={product.data.msrp}
              savings={product.data.savings}
              affiliate={product.data.affiliate}
              desc={product.body}
              specs={product.data.specs}
              pros={product.data.pros}
              cons={product.data.cons}
              tags={product.data.tags}
              inStock={product.data.inStock}
              nextDay={product.data.nextDay}
              loadoutCount={product.data.loadoutCount}
            />
          </div>
        ))}
      </div>
      <div class="carousel__dots" id="carousel-dots" aria-hidden="true">
        {featuredProducts.map((_, i) => (
          <button class:list={['carousel__dot', i === 0 && 'active']} data-index={i} aria-label={`Go to slide ${i + 1}`}></button>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ COLLECTION TABS ═══ -->
  <section aria-label="Browse by collection" style="border-bottom: 1px solid var(--color-border);">
    <div class="section-head">
      <span class="section-head__label">Collections</span>
      <span class="section-head__title">Shop by Vibe</span>
    </div>

    <div class="collection-tabs-bar" id="collection-tabs" role="tablist" aria-label="Browse by collection">
      {collectionProducts.map((col, i) => (
        <button
          role="tab"
          class:list={['collection-tab', i === 0 && 'active']}
          data-collection={col.id}
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-controls={`panel-${col.id}`}
          id={`tab-${col.id}`}
        >
          <span class="collection-tab__emoji">{col.emoji}</span>
          <span class="collection-tab__label">{col.label}</span>
        </button>
      ))}
    </div>

    {collectionProducts.map((col, i) => (
      <div
        role="tabpanel"
        id={`panel-${col.id}`}
        class:list={['collection-panel', i !== 0 && 'hidden']}
        aria-labelledby={`tab-${col.id}`}
        aria-hidden={i !== 0 ? 'true' : 'false'}
      >
        <div class="quick-picks">
          <div class="quick-pick-item">
            <span class="label">Best Overall</span>
            <span class="name">{col.products[0]?.data.name || 'Top Pick'}</span>
          </div>
          <div class="quick-pick-item">
            <span class="label">Best Value</span>
            <span class="name">{col.products.find(p => p.data.tags.includes('budget') || p.data.tags.includes('value'))?.data.name || 'Value Pick'}</span>
          </div>
          <div class="quick-pick-item">
            <span class="label">Premium Pick</span>
            <span class="name">{col.products.find(p => p.data.tags.includes('pro') || p.data.tags.includes('premium'))?.data.name || 'Pro Pick'}</span>
          </div>
        </div>

        <div class="product-grid" style="padding-top: var(--space-4);">
          {col.products.map((product: any, rank: number) => product && (
            <ProductCard
              id={product.data.id}
              rank={rank + 1}
              name={product.data.name}
              brand={product.data.brand}
              badge={product.data.badge}
              seam={product.data.seam}
              emoji={product.data.emoji}
              price={product.data.price}
              priceRaw={product.data.priceRaw}
              msrp={product.data.msrp}
              savings={product.data.savings}
              affiliate={product.data.affiliate}
              desc={product.body}
              specs={product.data.specs}
              pros={product.data.pros}
              cons={product.data.cons}
              tags={product.data.tags}
              inStock={product.data.inStock}
              nextDay={product.data.nextDay}
              loadoutCount={product.data.loadoutCount}
            />
          ))}
        </div>
      </div>
    ))}
  </section>

  <!-- ═══ CATEGORY GRID ═══ -->
  <section class="section home-categories" aria-label="Browse by category" style="border-bottom: 1px solid var(--color-border);">
    <div class="section-head">
      <span class="section-head__label">Hardware</span>
      <span class="section-head__title">Browse by Category</span>
    </div>
    <div class="category-grid">
      {categories.map(cat => (
        <a href={`/${cat.slug}/`} class="category-tile">
          <span class="category-tile__icon" aria-hidden="true">{cat.icon}</span>
          <span class="category-tile__name">{cat.name}</span>
          <span class="category-tile__desc">{cat.count}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- ═══ COMPARISON STRIP ═══ -->
  <section class="section home-comparison" aria-label="Performance comparison" style="border-bottom: 1px solid var(--color-border);">
    <div class="section-head">
      <span class="section-head__label">Performance Data</span>
      <span class="section-head__title">Spec Comparison</span>
      <a href="/comparisons/" class="section-head__link">Full comparisons →</a>
    </div>
    <div class="comparison-strip" role="table" aria-label="Gear performance comparison">
      <div class="comparison-strip__row comparison-strip__row--head" role="row" aria-hidden="true">
        <span class="comparison-strip__label">Specification</span>
        <span class="comparison-strip__val" style="font-weight: var(--weight-semibold); color: var(--color-text-primary);">Entry Level</span>
        <span class="comparison-strip__val" style="color: var(--color-accent); font-weight: var(--weight-bold);">Pro / Flagship</span>
      </div>
      {specComparison.map(row => (
        <div class="comparison-strip__row" role="row">
          <span class="comparison-strip__label" role="cell">{row.label}</span>
          <span class="comparison-strip__val" role="cell">{row.a}</span>
          <span class="comparison-strip__val comparison-strip__val--accent" role="cell">{row.b}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ SETUP GUIDES ═══ -->
  <section class="section home-guides" aria-label="Setup guides" style="border-bottom: 1px solid var(--color-border);">
    <div class="section-head">
      <span class="section-head__label">Editorial</span>
      <span class="section-head__title">Setup Guides</span>
      <a href="/guides/" class="section-head__link">All guides →</a>
    </div>
    <div class="guide-grid">
      {featuredGuides.map(guide => (
        <a href={`/guides/${guide.slug}/`} class="guide-card">
          <span class="guide-card__icon" aria-hidden="true">{guide.data.emoji ?? '📋'}</span>
          <div class="guide-card__body">
            <span class="guide-card__budget">{guide.data.budgetLabel}</span>
            <span class="guide-card__title">{guide.data.heroTitle ?? guide.data.title}</span>
            <span class="guide-card__desc">{guide.data.heroSubtitle ?? guide.data.metaDescription}</span>
          </div>
          <span class="guide-card__arrow" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </span>
        </a>
      ))}
    </div>
  </section>

  <style>
    .quick-picks { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-4); margin-bottom: var(--space-8); padding: 0 var(--page-pad-mobile); }
    .quick-pick-item { background: var(--color-bg-inset); border: 1px solid var(--color-border); padding: var(--space-4); border-radius: 12px; text-align: center; }
    .quick-pick-item .label { display: block; font-size: 10px; text-transform: uppercase; color: var(--color-accent); font-weight: 800; margin-bottom: 4px; }
    .quick-pick-item .name { font-size: 14px; font-weight: 700; color: var(--color-text-primary); }
    @media (max-width: 600px) { .quick-picks { grid-template-columns: 1fr; } }
  </style>

  <script>
    // --- Carousel Logic ---
    const track = document.getElementById('carousel-track');
    const dots  = document.querySelectorAll('.carousel__dot');
    if (track && dots.length > 0) {
      let current = 0;
      const update = (idx: number) => {
        current = idx;
        const slideWidth = track.firstElementChild?.clientWidth || 0;
        track.scrollTo({ left: slideWidth * idx, behavior: 'smooth' });
        dots.forEach((d, i) => d.classList.toggle('active', i === idx));
      };
      dots.forEach((dot, i) => dot.addEventListener('click', () => update(i)));
      
      let isScrolling: any;
      track.addEventListener('scroll', () => {
        window.clearTimeout(isScrolling);
        isScrolling = setTimeout(() => {
          const idx = Math.round(track.scrollLeft / track.clientWidth);
          dots.forEach((d, i) => d.classList.toggle('active', i === idx));
        }, 100);
      });
    }

    // --- Tab Logic ---
    const tabs    = document.querySelectorAll<HTMLElement>('.collection-tab');
    const panels  = document.querySelectorAll<HTMLElement>('.collection-panel');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.collection;
        tabs.forEach(t => {
          t.classList.toggle('active', t === tab);
          t.setAttribute('aria-selected', t === tab ? 'true' : 'false');
        });
        panels.forEach(p => {
          const isTarget = p.id === `panel-${target}`;
          p.classList.toggle('hidden', !isTarget);
          p.setAttribute('aria-hidden', isTarget ? 'false' : 'true');
        });
      });
    });
  </script>

</Base>
