# ============================================================
#  STACK PICK — .gitignore
# ============================================================


# ── System & Environment ──────────────────────────────────────
.DS_Store
Thumbs.db
node_modules/
*.log
.env


# ── Editor & IDE ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo


# ── Auto-Generated Category Pages ────────────────────────────
# Built by generate-categories.js — never edit directly
/chairs/
/desks/
/headsets/
/keyboards/
/mice/
/monitors/
/pcs/
/speakers/
/extras/


# ── Auto-Generated Comparison & Guide Subpages ───────────────
# Ignores slug subfolders (e.g. /comparisons/mouse-vs-mouse/)
# but keeps the parent /comparisons/ and /guides/ folders tracked
/comparisons/*/
/guides/*/


# ── Auto-Generated Assets & SEO ──────────────────────────────
# Built by export-js-data.js and generate-sitemap.js
/assets/js/data/collections.js
/assets/js/data/products.js
/assets/js/data/search-index.js
/sitemap.xml


# ── Build-Stamped Source Files ────────────────────────────────
# These files contain __CSP_NONCE__ and __SP_VERSION__ placeholders
# that get stamped with real values during the build, then restored.
# They should never be committed mid-build with live values baked in.
# If a build crashes between Step 2 and Step 9, restore manually:
#   _headers:                      replace nonce-<value> with nonce-__CSP_NONCE__
#   _templates/_partials/head.html replace nonce="<value>" with nonce="__CSP_NONCE__"
#   sw.js:                         replace "sp-NNNNNNNNNNNNNN" with __SP_VERSION__
#
# Uncomment the lines below ONLY if you want to fully exclude these
# from git tracking (advanced — requires a separate deploy pipeline).
# _headers
# _templates/_partials/head.html
# sw.js