# ============================================================
#  STACK PICK — .gitignore
# ============================================================


# ── System & Environment ──────────────────────────────────────
.DS_Store
Thumbs.db
node_modules/
*.log
.env


# ── Editor & IDE ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo


# ── Auto-Generated Category Pages ────────────────────────────
# Built by generate-categories.js — never edit directly
/chairs/
/desks/
/headsets/
/keyboards/
/mice/
/monitors/
/pcs/
/speakers/
/extras/


# ── Auto-Generated Comparison & Guide Subpages ───────────────
# Ignores slug subfolders (e.g. /comparisons/mouse-vs-mouse/)
# but keeps the parent /comparisons/ and /guides/ folders tracked
/comparisons/*/
/guides/*/


# ── Auto-Generated Assets & SEO ──────────────────────────────
# Built by export-js-data.js and generate-sitemap.js
/assets/js/data/collections.js
/assets/js/data/products.js
/sitemap.xml
